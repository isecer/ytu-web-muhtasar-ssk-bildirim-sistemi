@using WebApp.Models;
@using BiskaUtil;
@model FmYevmiye1003AMuhatasarDokumu
@{
    Layout = "~/Views/Shared/_Layout.cshtml";
    var KayitYetki = RoleNames.YevmiyelerKayitYetkisi.InRole();
}

<div class="row">
    @using (Html.BeginForm("Index", "Yevmiye1003AMuhatasarDokumu", FormMethod.Post, new { id = "frmYevmiye1003AMuhatasarDokumu" }))
    {
        <div class="col-md-12">

            <div class="panel panel-danger" id="EkHbPanel">
                <div class="panel-heading padding-0">
                    <h3 class="panel-title"><i class="fa fa-list-alt"></i> 1003A Muhtasar Dökümü</h3>
                    <ul class="panel-controls">
                        <li>
                            <span>Yevmiye Yılı:</span>
                            <span class="label label-primary" style="padding:1px;padding-left:3px;padding-right:3px;">
                                @Html.DropDownList("Yil", null, new { @class = "form-control", onchange = "$('#frmYevmiye1003AMuhatasarDokumu').submit();", style = "color:black;min-width:220px;height:24px;" })
                            </span>
                        </li>
                        <li>
                            <span>Yevmiye Ay:</span>
                            <span class="label label-primary" style="padding:1px;padding-left:3px;padding-right:3px;">
                                @Html.DropDownList("AyID", null, new { @class = "form-control", onchange = "$('#frmYevmiye1003AMuhatasarDokumu').submit();", style = "color:black;min-width:220px;height:24px;" })
                            </span>
                        </li>
                        @if (Model.Data.Any())
                        {
                            <li><span class="label label-success" style="cursor:pointer;" onclick="window.location.href='@Url.Action("Index", "Yevmiye1003AMuhatasarDokumu", new {  Model.Yil, Model.AyID, export = true })'"> <img src="/Content/img/Excel-Icon.png" width="18" height="17"> Excel Olarak İndir</span></li>
                        }
                    </ul>
                </div>
                <div class="panel-body">
                    <table class="table table-hover">
                        <thead>
                            <tr>
                                <th width="70">Sıra No</th>
                                <th class="sirala sorting" field="VergiKodu">Vergi Kodu</th>
                                <th width="160" class="sirala sorting" field="Tutar" style="text-align:right;">Tutar</th>
                                <th width="160" class="sirala sorting" field="SksVergiTutar" style="text-align:right;">Sks Tutar</th>
                                <th width="160" class="sirala sorting" field="ImidVergiTutar" style="text-align:right;">İmid Tutar</th>
                                <th width="160" class="sirala sorting" field="KalanTutar" style="text-align:right;">Kalan Tutar</th>
                                <th width="160" class="sirala sorting" field="SksMatrahTutar" style="text-align:right;">Sks Matrah</th>
                                <th width="160" class="sirala sorting" field="ImidMatrahTutar" style="text-align:right;">İmid Matrah</th>
                                <th width="160" class="sirala sorting" field="GenelMatrahTutar" style="text-align:right;">Genel Matrah</th>
                                <th width="160" class="sirala sorting" field="KalanMatrah" style="text-align:right;">Kalan Matrah</th>
                                <th width="40"></th>
                            </tr>
                        </thead>
                        <tbody>
                            @{
                                int RowIndex = 0;
                                foreach (var item in Model.Data)
                                {
                                    RowIndex++;
                                    <tr>
                                        <td>
                                            @RowIndex
                                        </td>
                                        <td>
                                            @item.VergiKodu
                                        </td>
                                        <td style="text-align:right;">
                                            @item.Tutar.ToString("n2") TL
                                        </td>
                                        <td style="text-align:right;">
                                            @item.SksVergiTutar.ToString("n2") TL
                                        </td>
                                        <td style="text-align:right;">
                                            @item.ImidVergiTutar.ToString("n2") TL
                                        </td>
                                        <td style="text-align:right;">
                                            @item.KalanTutar.ToString("n2") TL
                                        </td>
                                        <td style="text-align:right;">
                                            @item.SksMatrahTutar.ToString("n2") TL
                                        </td>
                                        <td style="text-align:right;">
                                            @item.ImidMatrahTutar.ToString("n2") TL
                                        </td>
                                        <td style="text-align:right;">
                                            @item.GenelMatrahTutar.ToString("n2") TL
                                        </td>
                                        <td style="text-align:right;">
                                            @item.KalanMatrah.ToString("n2") TL
                                        </td>
                                        <td style="padding-left:10px;">
                                            @if (KayitYetki)
                                            {
                                                <a href="javascript:void(0)" onclick="TutarEkle(@Model.Yil,@Model.AyID,'@item.VergiKodu')"><i class="fa fa-edit fa-lg tooltips" data-style="blue" data-original-title="Tutar Düzelt"></i></a>
                                            }
                                        </td>
                                    </tr>
                                }
                                <tr class="info">

                                    <td colspan="3" style="text-align:right;font-weight:bold;">
                                        Genel Toplam: @Model.Data.Sum(s => s.Tutar).ToString("n2") TL
                                    </td>
                                    <td style="text-align:right;font-weight:bold;">
                                        @Model.Data.Sum(s => s.SksVergiTutar).ToString("n2") TL
                                    </td>
                                    <td style="text-align:right;font-weight:bold;">@Model.Data.Sum(s => s.ImidVergiTutar).ToString("n2") TL</td>
                                    <td style="text-align:right;font-weight:bold;">@Model.Data.Sum(s => s.KalanTutar).ToString("n2") TL</td>
                                    <td style="text-align:right;font-weight:bold;">@Model.Data.Sum(s => s.SksMatrahTutar).ToString("n2") TL</td>
                                    <td style="text-align:right;font-weight:bold;">@Model.Data.Sum(s => s.ImidMatrahTutar).ToString("n2") TL</td>
                                    <td style="text-align:right;font-weight:bold;">@Model.Data.Sum(s => s.GenelMatrahTutar).ToString("n2") TL</td>
                                    <td style="text-align:right;font-weight:bold;">@Model.Data.Sum(s => s.KalanMatrah).ToString("n2") TL</td>
                                    <td></td>
                                </tr>

                            }

                        </tbody>
                    </table>
                    @Model.ToSortSring()
                </div>
            </div>
        </div>
    }
</div>
<style>
    .btnleft {
        float: left;
    }
</style>
@if (KayitYetki)
{
    <script>
    function TutarEkle(Yil, AyID,VergiKodu) {
          var _panel = $('#EkHbPanel');
        _pRefresh(_panel, false);
        $.ajax({
            url: '@Url.Action("TutarEkle", "Yevmiye1003AMuhatasarDokumu")',
            data: { 'Yil': Yil, 'AyID': AyID, 'VergiKodu':VergiKodu },
            async: false,
            success: function (result) { 
                _pRefresh(_panel, false);
                var btbxxFS = bootbox.dialog({
                    message: result,
                    title: "<i class='fa fa-user-o fa-lg'></i>  Tutar Ekleme İşlemi",
                    buttons: {
                        success: {
                            label: 'Kaydet',
                            className: "btn-success",
                            callback: function (event) {
                                var pnlx = $(btbxxFS).find('.modal-dialog').first();
                                _pRefresh(pnlx, false);
                                $('#frmTutarKayit').ajaxForm({
                                    success: function (result) {
                                        if (result.IsSuccess) {
                                            toastr["success"](result.Messages[0], result.Title);
                                            var _clsBtn = $('.modal-header').find('button').first();
                                            $(_clsBtn).click();
                                            setTimeout($('#frmYevmiye1003AMuhatasarDokumu').submit(), 200);
                                        }
                                        else {
                                            getMsg(result);
                                            return false;
                                        }
                                        _pRefresh(pnlx, true);

                                    },
                                    complete: function (cmp) {
                                        _pRefresh(pnlx, true);
                                    },
                                    error: function (err) {
                                        _pRefresh(pnlx, true);
                                    }

                                }).submit();

                                return false;
                            }
                        },
                        danger: {
                            label: 'Kapat',
                            className: "btn-primary",
                            callback: function () {
                            }
                        }
                    }
                });
            },
            error: function (err) {
                _pRefresh(_panel, true);
                alert(err.responseText);
            }
        });
    }
    </script>
}