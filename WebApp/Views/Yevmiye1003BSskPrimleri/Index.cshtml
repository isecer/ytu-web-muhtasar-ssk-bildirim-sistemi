@using WebApp.Models;
@using BiskaUtil;
@model FmYevmiye1003BSskPrimleri
@{
    Layout = "~/Views/Shared/_Layout.cshtml";
    // var KayitYetki = RoleNames.YevmiyelerHarcamaBirimiToplamlariKayitYetkisi.InRole();
}

<div class="row">
    @using (Html.BeginForm("Index", "Yevmiye1003BSskPrimleri", FormMethod.Post, new { id = "frmYevmiye1003BSskPrimleri" }))
    {
        <div class="col-md-12">

            <div class="panel panel-danger" id="EkHbPanel">
                <div class="panel-heading padding-0">
                    <h3 class="panel-title"><i class="fa fa-list-alt"></i> Emekli Kesenek Harcama Birimi Toplamları</h3>
                    <ul class="panel-controls">
                        <li>
                            <span>Yevmiye Yılı:</span>
                            <span class="label label-primary" style="padding:1px;padding-left:3px;padding-right:3px;">
                                @Html.DropDownList("Yil", null, new { @class = "form-control", onchange = "$('#frmYevmiye1003BSskPrimleri').submit();", style = "color:black;min-width:220px;" })
                            </span>
                        </li>
                        <li>
                            <span>Yevmiye Ay:</span>
                            <span class="label label-primary" style="padding:1px;padding-left:3px;padding-right:3px;">
                                @Html.DropDownList("AyID", null, new { @class = "form-control", onchange = "$('#frmYevmiye1003BSskPrimleri').submit();", style = "color:black;min-width:220px;" })
                            </span>
                        </li>
                    </ul>
                </div>
                <div class="panel-body">
                    <table class="table table-hover">
                        <thead>
                            <tr>
                                <th width="70">Sıra No</th>
                                <th class="sirala sorting" field="BirimAdi">İşyeri Adı</th>
                                <th class="sirala sorting" field="IsyeriKodu">İşyeri Kodu</th>
                                <th class="sirala sorting" field="BelgeKodu">Belge Kodu</th>
                                <th class="sirala sorting" field="SskPrimTutarToplam" style="text-align:right;">Ssk Prim Toplam</th>
                                <th class="sirala sorting" field="YevmiyeAlacakToplam" style="text-align:right;">Gv Toplam</th>
                                <th class="sirala sorting" field="YevmiyeDvToplam" style="text-align:right;">Dv Toplam</th>
                                <th class="sirala sorting" field="YevmiyeMatrahToplam" style="text-align:right;">Matrah Toplam</th>
                                <th class="sirala sorting" field="SskTutarToplami" style="text-align:right;">Ssk Prim Fark</th>
                                <th class="sirala sorting" field="GvKesintiToplam" style="text-align:right;">Gv Fark</th>
                                <th class="sirala sorting" field="DvKesintiToplam" style="text-align:right;">Dv Fark</th>
                                <th class="sirala sorting" field="MatrahToplam" style="text-align:right;">Matrah Fark</th>
                                <th width="40"></th>
                            </tr>
                        </thead>
                        <tbody>
                            @{
                                int RowIndex = 0;
                                foreach (var item in Model.Data)
                                {
                                    RowIndex++;
                                    <tr>
                                        <td>
                                            @RowIndex
                                        </td>
                                        <td>
                                            @item.VergiKimlikNo - @item.BirimAdi
                                        </td>
                                        <td>
                                            @item.IsyeriKodu
                                        </td>
                                        <td>
                                            @item.BelgeKodu
                                        </td>
                                        <td style="text-align:right;">
                                            @item.SskPrimTutarToplam.ToString("n2") TL
                                        </td>
                                        <td style="text-align:right;">
                                            @item.YevmiyeAlacakToplam.ToString("n2") TL
                                        </td>
                                        <td style="text-align:right;">@item.YevmiyeDvToplam.ToString("n2") TL</td>
                                        <td style="text-align:right;">@item.YevmiyeMatrahToplam.ToString("n2") TL</td>
                                        <td style="text-align:right;">@item.SskTutarToplam.ToString("n2") TL</td>
                                        <td style="text-align:right;">@item.GvKesintiToplam.ToString("n2") TL</td>
                                        <td style="text-align:right;">@item.DvKesintiToplam.ToString("n2") TL</td>
                                        <td style="text-align:right;">@item.MatrahToplam.ToString("n2") TL</td>
                                        <td style="padding-left:10px;">
                                            @if (false)
                                            {
                                                <a href="javascript:void(0)" onclick="TutarEkle(@Model.Yil,@item.YevmiyeHarcamaBirimID)"><i class="fa fa-edit fa-lg tooltips" data-style="blue" data-original-title="Tutar Düzelt"></i></a>
                                            }
                                        </td>
                                    </tr>
                                }
                                <tr class="info">
                                    <td colspan="5" style="text-align:right;font-weight:bold;">
                                        Genel Toplam: @Model.Data.Sum(s => s.SskPrimTutarToplam).ToString("n2") TL
                                    </td>
                                    <td style="text-align:right;font-weight:bold;">
                                        @Model.Data.Sum(s => s.YevmiyeAlacakToplam).ToString("n2") TL
                                    </td>
                                    <td style="text-align:right;font-weight:bold;">@Model.Data.Sum(s => s.YevmiyeDvToplam).ToString("n2") TL</td>
                                    <td style="text-align:right;font-weight:bold;">@Model.Data.Sum(s => s.YevmiyeMatrahToplam).ToString("n2") TL</td>
                                    <td style="text-align:right;font-weight:bold;">@Model.Data.Sum(s => s.SskTutarToplam).ToString("n2") TL</td>

                                    <td style="text-align:right;font-weight:bold;">@Model.Data.Sum(s => s.GvKesintiToplam).ToString("n2") TL</td>

                                    <td style="text-align:right;font-weight:bold;">@Model.Data.Sum(s => s.DvKesintiToplam).ToString("n2") TL</td>

                                    <td style="text-align:right;font-weight:bold;">@Model.Data.Sum(s => s.MatrahToplam).ToString("n2") TL</td>
                                    <td></td>
                                </tr>

                            }

                        </tbody>
                    </table>
                    @Model.ToSortSring()
                </div>
            </div>
        </div>
    }
</div>
<style>
    .btnleft {
        float: left;
    }
</style>
@if (false)
{
    <script>
    function TutarEkle(Yil, YevmiyeHarcamaBirimID) {
          var _panel = $('#EkHbPanel');
        _pRefresh(_panel, false);
        $.ajax({
            url: '@Url.Action("TutarEkle", "YevmiyeHarcamaBirimiToplamlari")',
            data: { Yil, YevmiyeHarcamaBirimID },
            async: false,
            success: function (result) {
                _pRefresh(_panel, false);
                var btbxxFS = bootbox.dialog({
                    message: result,
                    title: "<i class='fa fa-user-o fa-lg'></i> Emekli Kesenek Birim Tutar Ekleme İşlemi",
                    buttons: {
                        info: {
                            label: 'Kayıtları Temizle',
                            className: "btn-info btnleft",
                            callback: function () {
                                $('#frmTutarKayit').find('input[name=Tutar]').each(function (inx,itmx) {
                                    $(itmx).val("");
                                });
                                return false;
                            }
                        },
                        success: {
                            label: 'Kaydet',
                            className: "btn-success",
                            callback: function (event) {
                                var pnlx = $(btbxxFS).find('.modal-dialog').first();
                                _pRefresh(pnlx, false);
                                $('#frmTutarKayit').ajaxForm({
                                    success: function (result) {
                                        if (result.IsSuccess) {
                                            toastr["success"](result.Messages[0], result.Title);
                                            var _clsBtn = $('.modal-header').find('button').first();
                                            $(_clsBtn).click();
                                            setTimeout($('#frmYevmiyeHarcamaBirimiToplamlari').submit(), 200);
                                        }
                                        else {
                                            getMsg(result);
                                            return false;
                                        }
                                        _pRefresh(pnlx, true);

                                    },
                                    complete: function (cmp) {
                                        _pRefresh(pnlx, true);
                                    },
                                    error: function (err) {
                                        _pRefresh(pnlx, true);
                                    }

                                }).submit();

                                return false;
                            }
                        },
                        danger: {
                            label: 'Kapat',
                            className: "btn-primary",
                            callback: function () {
                            }
                        }
                    }
                });
            },
            error: function (err) {
                _pRefresh(_panel, true);
                alert(err.responseText);
            }
        });
    }
    </script>
}