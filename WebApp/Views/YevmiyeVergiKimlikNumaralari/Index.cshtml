@using WebApp.Models;
@using BiskaUtil;
@model FmYevmiyelerVergiKimlikNumaralari
@{
    var IndexModel = (MIndexBilgi)ViewBag.IndexModel;
    Layout = "~/Views/Shared/_Layout.cshtml";
}

<div class="row">
    @using (Html.BeginForm())
    {
        <div class="col-md-12">

            <div class="panel panel-danger">
                <div class="panel-heading padding-0">
                    <h3 class="panel-title"><i class="fa fa-list-alt"></i>&nbsp; Vergi Kimlik Numaraları Listesi</h3>
                    <ul class="panel-controls">
                        <li><span class="label label-primary label-form"><a href="@Url.Action("Kayit")" style="color:white;"><i class="fa fa-plus fa-lg"></i> Yeni</a></span></li>
                        <li><span class="label label-info label-form">Toplam: <b>@IndexModel.Toplam</b></span></li>
                        <li><a href="javascript:void(0);" onclick="setTimeout(function(){window.location.href='@Url.Action("Index")';},600)" class="panel-refresh"><span class="fa fa-refresh"></span></a></li>
                    </ul>
                </div>
                <div class="panel-body">
                    <table class="table table-hover">
                        <thead>
                            <tr>
                                <th width="70">Sıra No</th>
                                <th class="sirala sorting" width="110" field="VergiKimlikNo">Vergi Kimlik No</th>
                                <th class="sirala sorting" field="AdSoyad">Ad Soyad</th>
                                <th class="sirala sorting" field="Adres">Adres</th>
                                <th width="35"></th>
                            </tr>
                        </thead>
                        <tbody>
                            <tr class="filtrele">
                                <th></th>
                                <th>
                                    <input name="VergiKimlikNo" type="text" value="@Model.VergiKimlikNo" class="form-control" />
                                </th>
                                <th><input name="AdSoyad" type="text" value="@Model.AdSoyad" class="form-control" /></th>
                                <th>
                                    <input name="Adres" type="text" value="@Model.Adres" class="form-control" />
                                </th>
                                <th></th>
                            </tr>
                            @if (Model.RowCount > 0)
                            {
                                int RowIndex = Model.StartRowIndex; string trCls = "odd";
                                foreach (var item in Model.Data)
                                {
                                    RowIndex++;
                                    trCls = RowIndex % 2 == 1 ? "" : "even";
                                    <tr class="@trCls">
                                        <td>
                                            @RowIndex
                                        </td>
                                        <td id="tdVkn_@item.YevmiyeVergiKimlikNoID">
                                            @item.VergiKimlikNo
                                        </td>
                                        <td id="tdAs_@item.YevmiyeVergiKimlikNoID">
                                            @item.AdSoyad
                                        </td>
                                        <td>
                                            @item.Adres
                                        </td>
                                        <td>
                                            <a href="@Url.Action("Kayit", "YevmiyeVergiKimlikNumaralari", new { id = item.YevmiyeVergiKimlikNoID })"><i class="fa fa-edit fa-lg tooltips" data-style="blue" data-original-title="Düzelt"></i></a>
                                            <a href="javascript:void(0)" onclick="SilmeOnay(this,@item.YevmiyeVergiKimlikNoID)"><i class="fa fa-trash-o fa-lg tooltips" data-style="blue" data-original-title="Sil"></i></a>
                                        </td>
                                    </tr>


                                }
                            }
                            else
                            {
                                <tr>
                                    <td colspan="5" style="text-align: center;">
                                        [Listelenen Kayıt Yok]
                                    </td>
                                </tr>
                            }

                        </tbody>
                    </table>
                </div>
                <div class="panel-footer">
                    @Model.ToPagerString()
                </div>
            </div>
        </div>
    }
</div>
<script type="text/javascript">
    function SilmeOnay(sndr, id) {
        var Vkn = $("#tdVkn_" + id).html();
        var AdSoyad = $("#tdAs_" + id).html();
        var SoruHtml = "<table style='table-layout:fixed;width:100%;'>" +
            "<tr><td width='30' style='padding-left:10px;'></td><td style='padding-right:10px;'>" + (Vkn + ' - ' + AdSoyad)+"</td></tr>"+
            "<tr><td width='30' style='color:maroon;padding-left:10px;'><i class='fa fa-info fa-2x'></i></td><td style='color:maroon;padding-right:10px;'>Seçilen Vergi Kimlik Numarasını Silmek İstiyor Musunuz?</td></tr>" +
            "</table>";
        bootbox.dialog({
            message:   SoruHtml,
            title: "Vergi Kimlik Numarası Silme İşlemi",
            buttons: {
                success: {
                    label: "Vergi Kimlik Numarasını Sil",
                    className: "btn-danger",
                    callback: function () {
                        Sil(sndr, id);
                    }
                },
                danger: {
                    label: "Vazgeç",
                    className: "btn-success",
                    callback: function () {
                    }
                }
            }
        });
    }
    function Sil(sndr, id) {
        $.ajax({
            url: '@Url.Action("Sil", "YevmiyeVergiKimlikNumaralari")',
            data: { id: id },
            success: function (result) {
                toastr[result.success ? "success" : "error"](result.message, "Vergi Kimlik Numarası Silme İşlemi");
                if (result.success) {
                    $(sndr).closest("tr").remove(); 
                }

            },
            error: function (err) {
                alert(err.responseText);
            }
        });
    }

    
    
</script>
