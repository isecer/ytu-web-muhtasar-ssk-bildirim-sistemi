@using BiskaUtil
@using WebApp.Models
@model FmYevmiyeYuzdeOnAsimElleGiris
@{
    var IndexModel = (MIndexBilgi)ViewBag.IndexModel;
    Layout = "~/Views/Shared/_Layout.cshtml";
    var aktifeAlmaYetkisi = User.IsInRole("YevmiyeYuzdeOnAsimElleGirisAktifeAlmaYetkisi");
}

<div class="row">
    @using (Html.BeginForm("Index", "YevmiyeYuzdeOnAsimElleGiris", FormMethod.Post, new { id = "frmListe" }))
    {
        @Html.Hidden("export", false)
        <div class="col-md-12">
            <div class="panel panel-danger">
                <div class="panel-heading padding-0">
                    <h3 class="panel-title">
                        <i class="fa fa-list-alt"></i> Yüzde On Aşım Elle Giriş Listesi
                    </h3>
                    <ul class="panel-controls">
                        <li>
                            <span class="label label-primary label-form">
                                <a href="@Url.Action("Kayit")" style="color:white;">
                                    <i class="fa fa-plus fa-lg"></i> Yeni
                                </a>
                            </span>
                        </li>
                        <li>
                            <span class="label label-info label-form">
                                Toplam: <b>@IndexModel.Toplam</b>
                            </span>
                        </li>

                        @if (Model.Data.Any())
                        {
                            <li><span class="label label-success" style="cursor:pointer;" onclick="ExportExcel();"> <img src="/Content/img/Excel-Icon.png" width="18" height="17"> Excel Olarak İndir</span></li>
                        }
                        <li>
                            <a href="javascript:void(0);"
                               onclick="setTimeout(function(){ window.location.href='@Url.Action("Index")'; }, 600)"
                               class="panel-refresh">
                                <span class="fa fa-refresh"></span>
                            </a>
                        </li>
                    </ul>
                </div>

                <div class="panel-body">
                    <table class="table table-hover">
                        <thead>
                            <tr>
                                <th width="70">Sıra No</th>
                                <th class="sirala sorting" width="120" field="Tarih">Tarih</th>
                                <th class="sirala sorting" width="350" field="HarcamaBirimAdi">Birim</th>
                                <th class="sirala sorting" width="240" field="HesapKod">Hesap Kodu/Adı</th> 
                                <th class="sirala sorting" field="Aciklama">Açıklama</th>
                                <th class="sirala sorting" field="BrutTutar">Brüt</th>
                                <th class="sirala sorting" width="100" field="IsAktif">Durum</th>
                                <th width="80"></th>
                            </tr>
                        </thead>
                        <tbody>
                            <tr class="filtrele">
                                <th></th>
                                <th>
                                    @Html.DropDownList("Yil", null, new { @class = "form-control" })
                                </th>
                                <th>
                                    @Html.DropDownList("YevmiyeHarcamaBirimID", null, new { @class = "form-control" })
                                </th>
                                <th>
                                    <input name="HesapKod" value="@Model.HesapKod" class="form-control" />
                                </th> 
                                <th>
                                    <input name="Aciklama" value="@Model.Aciklama" class="form-control" />
                                </th>
                                <th></th>
                                <th>
                                    <select name="IsAktif" class="form-control">
                                        <option value=""></option>
                                        <option value="true" @Model.IsAktif.ToSelected()>Aktif</option>
                                        <option value="false" @((Model.IsAktif == false).ToSelected())>Pasif</option>
                                    </select>
                                </th>
                                <th>
                                    <button type="submit" class="btn btn-info btn-sm">
                                        <i class="fa fa-search"></i>
                                    </button>
                                </th>
                            </tr>

                            @if (Model.Data != null && Model.Data.Any())
                            {
                                int RowIndex = Model.StartRowIndex;
                                string trCls = "";
                                foreach (var item in Model.Data)
                                {
                                    RowIndex++;
                                    trCls = RowIndex % 2 == 1 ? "" : "even";
                                    <tr class="@trCls" id="tr_@item.YevmiyeYuzdeOnAsimHesapElleGirisID">
                                        <td>@RowIndex</td>
                                        <td>
                                            @(item.Tarih.HasValue ? item.Tarih.Value.ToString("dd.MM.yyyy") : "")
                                        </td>
                                        <td id="tdBirim_@item.YevmiyeYuzdeOnAsimHesapElleGirisID">
                                            @item.HarcamaBirimAdi
                                        </td>
                                        <td>@item.HesapKod<br/>@item.HesapAdi</td>
                                        <td>@item.Aciklama</td>
                                        <td>@item.BrutTutar.ToString("n2")</td>
                                        <td id="tdDurum_@item.YevmiyeYuzdeOnAsimHesapElleGirisID">
                                            @if (item.IsAktif)
                                            {
                                                <span class="label label-success">AKTİF</span>
                                            }
                                            else
                                            {
                                                <span class="label label-danger">PASİF</span>
                                            }
                                        </td>
                                        <td>
                                            <a href="@Url.Action("Kayit", new { id = item.YevmiyeYuzdeOnAsimHesapElleGirisID })">
                                                <i class="fa fa-edit fa-lg tooltips" data-style="blue" data-original-title="Düzelt"></i>
                                            </a>
                                            <a href="javascript:void(0)" onclick="SilmeOnay(this, @item.YevmiyeYuzdeOnAsimHesapElleGirisID, '@item.HarcamaBirimAdi')">
                                                <i class="fa fa-trash-o fa-lg tooltips" data-style="blue" data-original-title="Sil"></i>
                                            </a>
                                            @if (item.IsAktif)
                                            {
                                                <a href="javascript:void(0)"
                                                   onclick="DurumDegistirOnay(@item.YevmiyeYuzdeOnAsimHesapElleGirisID, true)"
                                                   class="tooltips" data-original-title="Pasife Al">
                                                    <i class="fa fa-ban fa-lg" style="color:orange;"></i>
                                                </a>
                                            }
                                            else
                                            {
                                                if (aktifeAlmaYetkisi)
                                                {
                                                    <a href="javascript:void(0)"
                                                       onclick="DurumDegistirOnay(@item.YevmiyeYuzdeOnAsimHesapElleGirisID, false)"
                                                       class="tooltips" data-original-title="Aktife Al">
                                                        <i class="fa fa-check fa-lg" style="color:green;"></i>
                                                    </a>
                                                }
                                                else
                                                {
                                                    <i class="fa fa-lock fa-lg tooltips" style="color:gray;" data-original-title="Aktife Alma Yetkiniz Yok"></i>
                                                }
                                            }
                                        </td>
                                    </tr>
                                }
                            }
                            else
                            {
                                <tr>
                                    <td colspan="8" style="text-align:center;">
                                        [Listelenen Kayıt Yok]
                                    </td>
                                </tr>
                            }
                        </tbody>
                    </table>
                </div>

                <div class="panel-footer">
                    @Model.ToPagerString()
                </div>
            </div>
        </div>
    }
</div>

<script type="text/javascript">
    function ExportExcel() {
        $('#export').val('true');
        $('#frmListe').submit();
        $('#export').val('false');
    }
    function SilmeOnay(sndr, id, birimAdi) {
        var SoruHtml = "<table style='table-layout:fixed;width:100%;'>" +
            "<tr><td style='padding-left:10px;'>" + birimAdi + "</td></tr>" +
            "<tr><td style='color:maroon;padding-left:10px;'>" +
            "<i class='fa fa-info fa-2x'></i> Seçilen Kaydı Silmek İstiyor Musunuz?" +
            "</td></tr></table>";

        bootbox.dialog({
            message: SoruHtml,
            title: "Yüzde On Aşım Kaydı Silme İşlemi",
            buttons: {
                success: {
                    label: "Kaydı Sil",
                    className: "btn-danger",
                    callback: function () {
                        $.ajax({
                            url: '@Url.Action("Sil")',
                            data: { id: id },
                            success: function (result) {
                                toastr[result.success ? "success" : "error"](result.message, "Silme İşlemi");
                                if (result.success) {
                                    $(sndr).closest("tr").remove();
                                }
                            },
                            error: function (err) {
                                alert(err.responseText);
                            }
                        });
                    }
                },
                danger: {
                    label: "Vazgeç",
                    className: "btn-success",
                    callback: function () { }
                }
            }
        });
    }

    function DurumDegistirOnay(id, mevcutAktif) {
        var mesaj = mevcutAktif
            ? "Kayıt pasife alınsın mı?"
            : "Kayıt aktife alınsın mı?";
        var baslik = mevcutAktif
            ? "Pasife Alma İşlemi"
            : "Aktife Alma İşlemi";

        bootbox.dialog({
            message: "<i class='fa fa-info fa-lg' style='color:orange;'></i> " + mesaj,
            title: baslik,
            buttons: {
                success: {
                    label: mevcutAktif ? "Pasife Al" : "Aktife Al",
                    className: mevcutAktif ? "btn-warning" : "btn-success",
                    callback: function () {
                        $.ajax({
                            url: '@Url.Action("DurumDegistir")',
                            type: "POST",
                            data: { id: id },
                            success: function (result) {
                                toastr[result.success ? "success" : "error"](result.message, baslik);
                                if (result.success) {
                                    var yeniAktif = !mevcutAktif;
                                    var durumHtml = yeniAktif
                                        ? "<span class='label label-success'>AKTİF</span>"
                                        : "<span class='label label-danger'>PASİF</span>";
                                    $("#tdDurum_" + id).html(durumHtml);

                                    var tr = $("#tr_" + id);
                                    var eylemTd = tr.find("td:last");
                                    var durumBtn = eylemTd.find(".fa-ban, .fa-check, .fa-lock").parent();
                                    if (yeniAktif) {
                                        durumBtn.replaceWith(
                                            "<a href='javascript:void(0)' onclick='DurumDegistirOnay(" + id + ", true)' class='tooltips' data-original-title='Pasife Al'>" +
                                            "<i class='fa fa-ban fa-lg' style='color:orange;'></i></a>"
                                        );
                                    } else {
                                        @if (aktifeAlmaYetkisi)
                                        {
                                            <text>
                                            durumBtn.replaceWith(
                                                "<a href='javascript:void(0)' onclick='DurumDegistirOnay(" + id + ", false)' class='tooltips' data-original-title='Aktife Al'>" +
                                                "<i class='fa fa-check fa-lg' style='color:green;'></i></a>"
                                            );
                                            </text>
                                        }
                                        else
                                        {
                                            <text>
                                            durumBtn.replaceWith(
                                                "<i class='fa fa-lock fa-lg tooltips' style='color:gray;' data-original-title='Aktife Alma Yetkiniz Yok'></i>"
                                            );
                                            </text>
                                        }
                                    }
                                }
                            },
                            error: function (err) {
                                alert(err.responseText);
                            }
                        });
                    }
                },
                danger: {
                    label: "Vazgeç",
                    className: "btn-default",
                    callback: function () { }
                }
            }
        });
    }
</script>