@model Database.YevmiyelerYuzdeOnAsimHesapElleGirisler
@{
    Layout = "~/Views/Shared/_Layout.cshtml";
}

<div class="row">
    <form method="post" class="form-horizontal">

        @Html.HiddenFor(x => x.YevmiyeYuzdeOnAsimHesapElleGirisID)

        <div class="col-md-12">
            <div class="panel panel-default">

                <div class="panel-heading">
                    <h3 class="panel-title">
                        @(Model.YevmiyeYuzdeOnAsimHesapElleGirisID == 0 ? "Yeni Kayıt" : "Güncelle")
                    </h3>
                </div>

                <div class="panel-body form-group-separated">

                    <!-- TARİH -->
                    <div class="form-group">
                        <label class="col-md-3 control-label">Tarih</label>
                        <div class="col-md-9">
                            <input type="text" id="Tarih" name="Tarih"
                                   value="@(Model.Tarih!=DateTime.MinValue ? Model.Tarih.ToString("dd-MM-yyyy") : "")"
                                   class="form-control" />
                        </div>
                    </div>

                    <!-- HARCAMA BİRİMİ (NORMAL DROPDOWN) -->
                    <div class="form-group">
                        <label class="col-md-3 control-label">Harcama Birimi</label>
                        <div class="col-md-9">
                            @Html.DropDownListFor(m => m.YevmiyeHarcamaBirimID,
                                (IEnumerable<SelectListItem>)ViewBag.HarcamaBirimleri,
                                new { @class = "form-control" })
                        </div>
                    </div>

                    <!-- HESAP KOD (SELECT2) -->
                    <div class="form-group">
                        <label class="col-md-3 control-label">Hesap Kod</label>
                        <div class="col-md-9">
                            <input type="hidden" id="HesapKodID" name="YevmiyeHesapKodHavuzID" />
                        </div>
                    </div>

                    <!-- TUTAR -->
                    <div class="form-group">
                        <label class="col-md-3 control-label">Brüt Tutar</label>
                        <div class="col-md-9">
                            <input type="text" name="BrutTutar"
                                   value="@Model.BrutTutar"
                                   class="form-control" />
                        </div>
                    </div>

                    <!-- AÇIKLAMA -->
                    <div class="form-group">
                        <label class="col-md-3 control-label">Açıklama</label>
                        <div class="col-md-9">
                            <input type="text" name="Aciklama"
                                   value="@Model.Aciklama"
                                   class="form-control" />
                        </div>
                    </div>

                </div>

                <div class="panel-footer">
                    <a href="@Url.Action("Index")" class="btn btn-default">Geri</a>
                    <button class="btn btn-primary pull-right">Kaydet</button>
                </div>

            </div>
        </div>

    </form>
</div>

<script>

$(function () {

    // TARİH
    $('#Tarih').datetimepicker({
        lang: 'tr',
        timepicker: false,
        format: 'd-m-Y'
    });

    // HESAP KOD (SENİN PATTERN)
    $("#HesapKodID").select2({
        width: '100%',
        tags: true,
        minimumInputLength: 0,
        multiple: false,
        ajax: {
            url: '@Url.Action("GetHesapKodlari")',
            dataType: "json",
            data: function (term) {
                return { term: term }
            },
            results: function (data) {
                return { results: data };
            }
        },
        formatResult: function (result) {
            return "<div style='font-size:11px'>" +
                "<b>" + result.HesapKod + "</b><br/>" +
                "<span style='color:#888'>" + result.HesapAdi + "</span>" +
                "</div>";
        }
    });

    // EDIT MODE
    var secilen = @Html.Raw(Json.Encode(new {
                      id = Model.YevmiyeHesapKodHavuzID,
                      text = Model.YevmiyeHesapKodHavuzID > 0 ? (Model.HesapKod + " " + Model.HesapAdi) : ""
                  }));

    if (secilen.id != null && secilen.id != 0) {
        $("#HesapKodID").select2('data', secilen);
    }

});

</script>