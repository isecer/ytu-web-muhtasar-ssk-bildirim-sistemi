@using Database;
@using WebApp.Models;
@using BiskaUtil;
@model YevmiyelerBelgeKodlari
@{
    var MmMessage = ViewBag.MmMessage as MmMessage;
    Layout = "~/Views/Shared/_Layout.cshtml";
}
<div class="row">
    <form method="post" class="form-horizontal" role="form">
        <input type="text" style="display:none;" id="YevmiyeBelgeKodID" name="YevmiyeBelgeKodID" value="@Model.YevmiyeBelgeKodID" />
        <div class="col-md-12 col-md-12 col-md-12">
            <div class="panel panel-default" id="pUnvanK">
                <div class="panel-heading padding-0">
                    <h3 class="panel-title"><i class="fa fa-pencil"></i>&nbsp;@(Model.YevmiyeBelgeKodID <= 0 ? "Yeni Belge Kodu Tanımlama İşlemi" : "Belge Kodu Düzeltme İşlemi") </h3>
                    <ul class="panel-controls">
                        <li><a href="@Url.Action("Kayit", Model.YevmiyeBelgeKodID)" class=""><span class="fa fa-refresh panel-refresh"></span></a></li>
                    </ul>
                </div>
                <div class="panel-body">
                    <div class="panel panel-default form-horizontal">
                        <div class="panel-body form-group-separated">
                            <div class="form-group">
                                <label class="col-md-3 col-xs-4 control-label">Belge Tür Kodu</label>
                                <div class="col-md-9 col-xs-8">
                                    <input type="text" name="BelgeKodu" id="BelgeKodu" maxlength="2" value="@Model.BelgeKodu" class="form-control" autocomplete="off"/>
                                </div>
                            </div>
                            <div class="form-group">
                                <label class="col-md-3 col-xs-4 control-label">Belge Tür Adı</label>
                                <div class="col-md-9 col-xs-8">
                                    <input type="text" name="BelgeAdi" id="BelgeAdi" maxlength="256" value="@Model.BelgeAdi" class="form-control" autocomplete="off"/>
                                </div>
                            </div>
                          
                            
                        </div>
                    </div>
                </div>
                <div class="panel-footer">
                    <a href="@Url.Action("Index")" class="btn btn-default"><i class="fa fa-reply">&nbsp</i>Geri Dön</a>
                    <button class="btn btn-primary pull-right"><i class="fa fa-save">&nbsp</i>Kaydet</button>
                </div>
            </div>
        </div>
    </form>
</div>
<script>

    $(function () {
        var model = '@Html.Raw(Json.Encode(MmMessage))';
        validateControl(model);
    });

</script>

