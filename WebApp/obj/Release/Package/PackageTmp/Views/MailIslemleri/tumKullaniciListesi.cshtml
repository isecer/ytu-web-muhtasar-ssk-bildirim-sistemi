@using .Models
@model IEnumerable<mailkullanicibilgi>

<table class="table table-striped table-hover">
    <tr>
        <th style="padding: 1px; font-size: 8pt; width: 200px;">Ad Soyad</th>
        <th style="padding: 1px; font-size: 8pt;">Birim</th>
        <th style="padding: 1px; font-size: 8pt; width: 160px;">Lokasyon / Blok / Daire Tipi</th>

    </tr>
    <tr>
        <td style="padding: 0px;">
            <input type="text" name="FAdSoyad" id="FAdSoyad" style="width: 100%;" /></td>
        <td style="padding: 0px;">
            <input type="text" name="FBirimAdi" id="FBirimAdi" style="width: 100%;" /></td>
        <td style="padding: 0px;">
            <input type="text" name="FLokasyon" id="FLokasyon" style="width: 100%;" /></td>
    </tr>

    <tr>
        <td colspan="3" style="padding: 0px;">
            <div style="height: 200px; overflow: auto;">
                <table class="table  table-hover" style="margin: 0px;">
                    @foreach (var item in Model.Select((s, inx) => new { inx, s }))
                    {
                        <tr class="mainRow">
                            <td class="name" style="padding: 0px; width: 200px;">
                                <label style="font-size:8pt;cursor:pointer; margin:0px;@(item.s.Checked ? "color: blue;" : "color:black")">
                                    <table>
                                        <tr>
                                            <td>
                                                <input type="checkbox" name="KullaniciIDs"   class="ace" value="@item.s.KullaniciID" @(item.s.Checked ? "checked" : "") onchange="countHesapla('tPersT')">
                                            </td>
                                            <td>
                                                <table class="FAdSoyad">
                                                    <tr style="line-height: 10px;">
                                                        <td style="font-size: 8pt; color: #085614;">
                                                            <img src="~/Images/User-green.png" style="height: 16px;" />
                                                            @item.s.AdSoyad</td>
                                                    </tr>
                                                    <tr style="line-height: 10px;">
                                                        <td style="font-size: 7pt; color: #085614;">
                                                            <img src="~/Images/Email.png" style="height: 16px;" />
                                                            @item.s.Email</td>
                                                    </tr>
                                                </table>
                                            </td>
                                        </tr>
                                    </table>

                                </label>
                            </td>
                            <td style="padding: 0px;font-size:7pt; @(item.s.Checked ? "color: blue;" : "color:black")" class="FBirimAdi">@item.s.BirimAdi</td>
                            <td style="font-size: 8pt;padding:0px;width: 140px;@(item.s.Checked ? "color: blue;" : "color:black")">
                                <table style="width: 100%; table-layout: fixed;" class="FLokasyon">
                                    <tr>
                                        <td>@(item.s.LokasyonAdi + " / " + item.s.BlokNo)</td>
                                    </tr>
                                    <tr>
                                        <td>@(item.s.CepheAdi + " / " + item.s.KapiNo) </td>
                                    </tr>
                                </table>

                            </td>
                        </tr>
                                                                                        
                           
                    }
                </table>
            </div>
        </td>
    </tr>
    <tr>
        <td style="padding: 0px;">Seçilen: <span id="C_T_tPersT">@Model.Where(p => p.Checked).Count() Kişi</span></td>
        <td style="padding: 0px;"></td>
        <td style="padding: 0px;">Toplam Kullanıcı: @Model.Count()</td>
    </tr>
</table>

<script>
    $(function () {

    })

</script>
