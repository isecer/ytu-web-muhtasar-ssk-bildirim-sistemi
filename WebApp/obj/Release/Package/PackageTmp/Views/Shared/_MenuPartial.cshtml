@using WebApp.Models;
@using Database;
@using BiskaUtil;
@{
    Layout = null;
    var urlInfo = Request.Url.ToUrlInfo();
     

    var apath = Request.Url.AbsolutePath.IndexOf("?") > -1 ? Request.Url.AbsolutePath.Substring(0, Request.Url.AbsolutePath.IndexOf("?")) : Request.Url.AbsolutePath;

    var spl = apath.Split('/').Where(p => p != "").Select((item, inx) => new { item, inx }).ToList();

    var menudata = Management.GetAllMenu().ToList();
    var mMenu = new List<Menuler>();

    mMenu = Management.GetUserMenus().ToList();
    IEnumerable<Menuler> eklenecekler = new Menuler[0];
    do
    {
        
        var pids = mMenu.Where(p => p.BagliMenuID.HasValue && p.BagliMenuID.Value > 0).Select(s => s.BagliMenuID.Value);
        var ids = mMenu.Select(s => s.MenuID);
        var ekiskIds = pids.Except(ids);
        eklenecekler = menudata.Where(p => ekiskIds.Contains(p.MenuID)).ToArray();

        mMenu.AddRange(eklenecekler);
    }
    while (eklenecekler.Count() > 0);

    mMenu.AddRange(menudata.Where(p => p.YetkisizErisim.HasValue && p.YetkisizErisim.Value && mMenu.Any(a => a.MenuID == p.MenuID) == false));
    mMenu = mMenu.OrderBy(o => o.SiraNo).ToList();



    var sb = new System.Text.StringBuilder();
    Func<int?, bool> fxMenu = null;
}
@{
    fxMenu = new Func<int?, bool>((parentID) =>
    {
        Menuler[] menuler = null;
        if (!parentID.HasValue)
        {
            menuler = mMenu.Where(p => p.BagliMenuID == 0).ToArray();
        }
        else
        {
            menuler = mMenu.Where(p => p.BagliMenuID == parentID).ToArray();
        }
        if (menuler.Count() > 0)
        {
            for (int i = 0; i < menuler.Count(); i++)
            {
                var menu = menuler[i];
                string menuAdi =   menu.MenuAdi;
                string MenuAD = "<span class='"+(parentID.HasValue?"": "xn-text") +"'>" + menuAdi + "</span>";  
                string autC = menu.AuthenticationControl;
                bool navAutC = !menu.AuthenticationControl.IsNullOrWhiteSpace();
                var hrefUrl = navAutC || menu.MenuUrl.IsNullOrWhiteSpace() ? "javascript:void(0);" : (urlInfo.Root + menu.MenuUrl);

                var hassubmenu = (mMenu.Any(a => a.BagliMenuID == menu.MenuID));
                var IsActive= (mMenu.Any(a => a.BagliMenuID == menu.MenuID && ("/"+a.MenuUrl.Replace("I","i").ToLower())==urlInfo.LastPath)) || hrefUrl.Replace("I","i").ToLower()==urlInfo.LastPath;
                sb.AppendLine("<li class='" + (hassubmenu ? "xn-openable" : "") + (IsActive?" active":"")+ "'>" +
                                    "<a href='" + hrefUrl + "' " + (navAutC ? ("onclick='" + autC + "'") : "") + " menuurl='" + urlInfo.Root.ToLower() +  menu.MenuUrl.Replace("I", "i").ToLower() + "'>" +
                                       "<i class='" + menu.MenuCssClass + "' style='margin-right:3px;'></i>" + MenuAD +
                                    "</a>");
                if (hassubmenu)
                {
                    sb.AppendLine("<ul>");
                    fxMenu(menu.MenuID);
                    sb.AppendLine("</ul>");
                }
                sb.AppendLine("</li>");
            }
        }

        return true;
    });


    fxMenu(null);

}
@Html.Raw(sb.ToString())

