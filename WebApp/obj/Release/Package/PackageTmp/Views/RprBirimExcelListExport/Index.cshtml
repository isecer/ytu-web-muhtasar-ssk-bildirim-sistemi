@using WebApp.Models
@{
    ViewBag.Title = "Index";
    var BirimList = (List<ComboModelInt>)ViewBag.Birimler;
}

<div class="row">
    @using (Html.BeginForm("Index", "RprBirimExcelListExport", FormMethod.Post, new { id = "frmRprBirimExcelListExport" }))
    {

        <div class="col-md-12">

            <!-- START SIMPLE DATATABLE -->
            <div class="panel panel-info" id="pnlFltr">
                <div class="panel-heading padding-0">
                    <h3 class="panel-title">
                        <i class="fa fa-list-alt"></i> Birim Bildirimlerini Excel Olarak İndirme İşlemi
                    </h3>
                </div>
                <div class="panel-body">
                    <table class="table table-hover" style="table-layout:fixed;">
                        <tr>

                            <td width="120">Süreç</td>
                            <td>
                                @Html.DropDownList("VASurecID", null, new { @class = "form-control", onchange = "GetAyData()" })
                            </td>
                        </tr>
                        <tr>

                            <td>Ay</td>
                            <td>
                                @Html.DropDownList("AyID", null, new { @class = "form-control" })
                            </td>
                        </tr>
                        <tr>
                            <td>Birimler</td>
                            <td>
                                <table class="table table-hover" style="width:100%;table-layout:fixed;">
                                    <tr>
                                        <th>Birim Adı</th>
                                        <th width="160">
                                            <ul class="panel-controls">
                                                <li>
                                                    Tümünü Seç:<div class="make-switch switch-small" data-on-label="Evet" data-off-label="Hayır">
                                                        <input type="checkbox" value="true" name="IsAdmin" onchange="tumunusec(this)" class="toggle" />
                                                    </div>
                                                </li>
                                            </ul>
                                            <script>
                                                function tumunusec(sndr) {
                                                    var chkD = $(sndr).prop("checked");
                                                    $(".chks").each(function (inx, itmx) {
                                                        if ($(itmx).is(':disabled') == false) {
                                                            if (chkD) { $(itmx).parent().addClass("checked"); }
                                                            else { $(itmx).parent().removeClass("checked"); }
                                                            $(itmx).prop("checked", chkD);
                                                        }
                                                    });


                                                }
                                            </script>
                                        </th>

                                    </tr>


                                    <tr>
                                        <td colspan="2">
                                            <div style="overflow-y:auto;max-height:350px;">
                                                <table class="table table-hover" style="table-layout:fixed;width:100%;">
                                                    @foreach (var item in BirimList)
                                                    {
                                                        <tr>
                                                            <td>
                                                                <div class="checkbox pull-left">
                                                                    <label>
                                                                        <input type="checkbox" class="icheckbox chks" name="BirimID" value="@item.Value">
                                                                        @item.Caption
                                                                    </label>
                                                                </div>
                                                            </td>
                                                            <td width="120"></td>
                                                        </tr>
                                                    }
                                                </table>
                                            </div>
                                        </td>
                                    </tr>
                                </table>

                            </td>
                        </tr>
                        <tr>
                            <td colspan="2" style="text-align:center;">
                                <button class="btn btn-info"><i class="fa fa-list-alt fa-lg">&nbsp</i> Excel Olarak İndir</button> 
                            </td>
                        </tr>
                    </table>
                </div>
            </div>
        </div>

    }
</div>
<script>

    function GetAyData() {
        var _VASurecID = $('#VASurecID').val();
        var _AyID = $('#AyID').val();
        var _panel = $('#pnlFltr');
        _pRefresh(_panel, false);
        $.ajax({
            url: '@Url.Action("getAyBilgisi", "RprBirimExcelListExport")',
            data: { VASurecID: _VASurecID },
            success: function (result) {
                _pRefresh(_panel, true);
                $('#AyID').empty();
                var opt = "";
                for (var i = 0; i < result.length; i++) {
                    var _val = "";
                    var _text = "";
                    if (result[i].Value != null) {
                        _val = result[i].Value;
                        _text = result[i].Caption;
                    }
                    opt += "<option value='" + _val + "'" + (_val == _AyID ? "selected='selected'" : "") + ">" + _text + "</option>"
                }
                $('#AyID').append(opt);
            },
            error: function (err) {
                _pRefresh(_panel, true);
                alert(err.responseText);
            }
        });
    }
</script>
