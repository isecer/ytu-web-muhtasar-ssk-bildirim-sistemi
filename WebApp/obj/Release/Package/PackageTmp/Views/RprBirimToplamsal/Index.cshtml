@using WebApp.Models
@{
    ViewBag.Title = "Index";
    var BirimList = (List<ComboModelInt>)ViewBag.Birimler;
}


<div class="col-md-12">

    <!-- START SIMPLE DATATABLE -->
    <div class="panel panel-info" id="pnlFltr">
        <div class="panel-heading padding-0">
            <h3 class="panel-title">
                <i class="fa fa-bar-chart-o"></i> Birim Toplamsal Raporu Alma İşlemi
            </h3>
        </div>
        <div class="panel-body">
            <table class="table table-hover" style="table-layout:fixed;">
                <tr>

                    <td width="120">Süreç</td>
                    <td>
                        @Html.DropDownList("VASurecID", null, new { @class = "form-control" , onchange= "GetAyData()" })
                    </td>
                </tr>
                <tr>

                    <td>Ay</td>
                    <td>
                        @Html.DropDownList("AyID", null, new { @class = "form-control" })
                    </td>
                </tr>
                <tr>
                    <td>Birim</td>
                    <td>
                        <table class="table table-hover" style="width:100%;table-layout:fixed;">
                            <tr>
                                <th>Birim Adı</th>
                                <th width="160">
                                    <ul class="panel-controls">
                                        <li>
                                            Tümünü Seç:<div class="make-switch switch-small" data-on-label="Evet" data-off-label="Hayır">
                                                <input type="checkbox" value="true" name="IsAdmin" onchange="tumunusec(this)" class="toggle" />
                                            </div>
                                        </li>
                                    </ul>
                                    <script>
                                        function tumunusec(sndr) {
                                            var chkD = $(sndr).prop("checked");
                                            $(".chks").each(function (inx, itmx) {
                                                if ($(itmx).is(':disabled') == false) {
                                                    if (chkD) { $(itmx).parent().addClass("checked"); }
                                                    else { $(itmx).parent().removeClass("checked"); }
                                                    $(itmx).prop("checked", chkD);
                                                }
                                            });


                                        }
                                    </script>
                                </th>

                            </tr>


                            <tr>
                                <td colspan="2">
                                    <div style="overflow-y:auto;max-height:350px;">
                                        <table class="table table-hover" style="table-layout:fixed;width:100%;">
                                            @foreach (var item in BirimList)
                                            {
                                                <tr>
                                                    <td>
                                                        <div class="checkbox pull-left">
                                                            <label>
                                                                <input type="checkbox" class="icheckbox chks" name="BirimID" value="@item.Value">
                                                                @item.Caption
                                                            </label>
                                                        </div>
                                                    </td>
                                                    <td width="120"></td>
                                                </tr>
                                            }
                                        </table>
                                    </div>
                                </td>
                            </tr>
                        </table>

                    </td>
                </tr>
                <tr>
                    <td colspan="2" style="text-align:center;">
                        <a href="javascript:void(0);" onclick="RaporAl();" class="btn btn-info"><i class="fa fa-bar-chart-o fa-lg"></i> Rapor Al</a>
                    </td>
                </tr>
            </table>
        </div>
    </div>
</div>

<script>
    function RaporAl() {
        var _VASurecID = $("#VASurecID").val();
        if (_VASurecID == null || _VASurecID == "") {
            alert("Süreç Seçiniz.");
            return false;
        }
        var _BirimID = GetCheckedValues();
        if (_BirimID.length <= 0) {
            alert("En az bir birim seçiniz.");
            return false;
        }
        var _AyID = $("#AyID").val();
        yeniDialogBB(null, 'Birim Toplamsal Raporu', '@Url.Action("GetDxReport","Ajax")?RaporTipID=' + @RaporTipleri.BirimToplamsalRapor + '&VASurecID=' + _VASurecID + '&BirimID=' + _BirimID + '&AyID=' + _AyID, 'auto', 'modal-dialog modal-lg');

    }
    function GetCheckedValues() {
        var IDList = [];
        $(".chks").each(function (inx, itmx) {
            if ($(itmx).is(':checked')) {
                IDList.push($(itmx).val());
            }
        });

        return IDList;
    }
    function GetAyData() {
        var _VASurecID = $('#VASurecID').val();
        var _AyID = $('#AyID').val();
        var _panel = $('#pnlFltr');
        _pRefresh(_panel, false);
        $.ajax({
            url: '@Url.Action("getAyBilgisi", "RprBirimToplamsal")',
            data: { VASurecID: _VASurecID },
            success: function (result) {
                _pRefresh(_panel, true);
                $('#AyID').empty();
                var opt = "";
                for (var i = 0; i < result.length; i++) {
                    var _val = "";
                    var _text = "";
                    if (result[i].Value != null) {
                        _val = result[i].Value;
                        _text = result[i].Caption;
                    }
                    opt += "<option value='" + _val + "'" + (_val == _AyID ? "selected='selected'" : "") + ">" + _text + "</option>"
                }
                $('#AyID').append(opt);
            },
            error: function (err) {
                _pRefresh(_panel, true);
                alert(err.responseText);
            }
        });
    } 
</script>