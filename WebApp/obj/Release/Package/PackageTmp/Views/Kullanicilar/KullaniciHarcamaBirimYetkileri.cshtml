@using BiskaUtil
@using Database
@using WebApp.Models;
@model IEnumerable<YevmiyelerHarcamaBirimleri>
@{
    Layout = "~/Views/Shared/_Layout.cshtml";

    var user = (Kullanicilar)ViewBag.Kullanici;
    var yetkiliBirimleri = (List<KullaniciYevmiyeHarcamaBirimleri>)ViewBag.YetkiliBirimleri;
    var allchecked = yetkiliBirimleri.Count == Model.Count();
    var kullaniciKayit = RoleNames.KullaniciKayit.InRole();
}

<div class="row">
    <form method="post" id="kulSbmtFrm" class="form-horizontal" role="form">
        <div class="col-md-12">
            <div class="panel panel-default">
                <div class="portlet-title">
                    <div class="panel-heading padding-0">
                        <h3 class="panel-title">
                            <i class="fa fa-home"></i>
                            Yevmiye Harcama Birim Yetkileri: @user.Ad @user.Soyad [@user.KullaniciAdi]
                        </h3>
                        <ul class="panel-controls">
                            <li>
                                Tümü:
                                <div class="make-switch switch-small" data-on-label="Evet" data-off-label="Hayır" style="z-index:0">
                                    <input type="checkbox" value="true" id="tmunusec" onchange="tumunusec(this)" class="toggle" @allchecked.ToChecked() />
                                </div>
                            </li>
                            @if (kullaniciKayit)
                            {
                                <li>
                                    <span class="label label-info label-form"
                                          onclick="window.location.href='@Url.Action("Kayit", new { id = user.KullaniciID })'"
                                          style="cursor:pointer;">
                                        <i class="fa fa-user"></i> Kullanıcı
                                    </span>
                                </li>
                                <li>
                                    <span class="label label-info label-form"
                                          onclick="window.location.href='@Url.Action("Yetkilendirme", new { id = user.KullaniciID })'"
                                          style="cursor:pointer;">
                                        <i class="fa fa-lock"></i> Erişim Yetkileri
                                    </span>
                                </li>
                                <li>
                                    <span class="label label-info label-form"
                                          onclick="window.location.href='@Url.Action("KullaniciBirimYetkileri", new { id = user.KullaniciID })'"
                                          style="cursor:pointer;">
                                        <i class="fa fa-lock"></i> İşçi İşlemleri Birim Yetkileri
                                    </span>
                                </li>
                                <li>
                                    <span class="label label-info label-form"
                                          onclick="window.location.href='@Url.Action("KullaniciYevmiyeHesapKodTurYetkileri", new { id = user.KullaniciID })'"
                                          style="cursor:pointer;">
                                        <i class="fa fa-lock"></i> Yevmiye Hesap Tür Kod Yetkileri
                                    </span>
                                </li>
                            }
                            <li>
                                <a href="@Url.Action("KullaniciHarcamaBirimYetkileri", "Kullanicilar", new { id = user.KullaniciID })">
                                    <span class="fa fa-refresh panel-refresh"></span>
                                </a>
                            </li>
                        </ul>
                    </div>
                </div>

                <div class="panel-body form">
                    <input type="hidden" name="KullaniciID" value="@user.KullaniciID" />

                    <table class="table" style="width:100%;table-layout:fixed;">
                        <thead>
                            <tr>
                                <th>Harcama Birim Adı</th>
                            </tr>
                            <tr>
                                <td colspan="2">
                                    <table style="width:100%;">
                                        <tr>
                                            <td>
                                                <div style="width:100%;" class="checkbox pull-left">
                                                    <label style="width:100%;">
                                                        <input style="width:100%;" type="text" name="search"
                                                               id="filterBInp" placeholder="ara..."
                                                               class="form-control">
                                                    </label>
                                                </div>
                                            </td>
                                            <td></td>
                                        </tr>
                                    </table>
                                </td>
                            </tr>
                        </thead>
                        <tbody>
                            @if (Model.Any())
                            {
                                <tr>
                                    <td colspan="2">
                                        <div style="overflow:auto;height:600px;">
                                            <table id="prgList" style="table-layout:fixed;width:100%;">
                                                @foreach (var item in Model)
                                                {
                                                    var yetkiVar = yetkiliBirimleri.Any(a => a.YevmiyeHarcamaBirimID == item.YevmiyeHarcamaBirimID);
                                                    <tr class="_rows" @(yetkiVar ? "style=color:blue" : "")>
                                                        <td>
                                                            <div class="checkbox pull-left">
                                                                <label>
                                                                    <input type="checkbox"
                                                                           class="icheckbox chkAll"
                                                                           name="HarcamaBirimID"
                                                                           value="@item.YevmiyeHarcamaBirimID"
                                                                           @yetkiVar.ToChecked()>
                                                                    <span class="birimAdlari">
                                                                        @item.BirimAdi.Trim()
                                                                        @if (!string.IsNullOrWhiteSpace(item.VergiKimlikNo))
                                                                        {
                                                                            <small class="text-muted">(@item.VergiKimlikNo)</small>
                                                                        }
                                                                    </span>
                                                                </label>
                                                            </div>
                                                        </td>
                                                    </tr>
                                                }
                                            </table>
                                        </div>
                                    </td>
                                </tr>
                            }
                            else
                            {
                                <tr>
                                    <td colspan="2" style="text-align:center;">
                                        [ Listelenen Kayıt Yok ]
                                    </td>
                                </tr>
                            }
                            <tr>
                                <td id="filtreKelime" colspan="2"></td>
                            </tr>
                        </tbody>
                    </table>
                </div>

                <div class="panel-footer">
                    <a href="@Url.Action("Index")" class="btn btn-default">
                        <i class="fa fa-reply">&nbsp</i>Geri Dön
                    </a>
                    <button class="btn btn-primary pull-right">
                        <i class="fa fa-save">&nbsp</i>Kaydet
                    </button>
                    <input type="hidden" id="YetkilendirmeyeGit" name="YetkilendirmeyeGit" value="false" />
                    <a href="javascript:void(0);"
                       class="btn btn-default pull-right"
                       onclick="$('#YetkilendirmeyeGit').val('true'); $('#kulSbmtFrm').submit();">
                        <i class="fa fa-save">&nbsp</i>Kaydet ve Erişim Yetkilerine Git
                    </a>
                </div>
            </div>
        </div>
    </form>
</div>

<script type="text/javascript">
    function tumunusec(sndr) {
        var chkD = $(sndr).prop("checked");
        $('.chkAll').each(function (inx, itmx) {
            if ($(itmx).parents('._rows').first().css('display') != "none") {
                if (chkD) { $(itmx).parent().addClass("checked"); }
                else { $(itmx).parent().removeClass("checked"); }
                $(itmx).prop("checked", chkD);
            }
        });
    }

    function Filtrele() {
        var filtreval = $('#filterBInp').val().replace('İ', 'i').toLowerCase();
        var toplam = $('._rows').length;

        if (filtreval != null && filtreval != "") {
            $('#prgList').find('tr').each(function (inx, trx) {
                var birimAdi = $(trx).find(".birimAdlari").first().text();
                var normalized = birimAdi.replace('İ', 'i').toLowerCase();
                var gorunsun = normalized.indexOf(filtreval) > -1;
                if (gorunsun) { $(trx).removeClass("hide"); }
                else { $(trx).addClass("hide"); }
            });

            var gizli = $('._rows.hide').length;
            var gosterilen = toplam - gizli;
            $('#filtreKelime').html(
                "[Ara: %<span style='color:red;'>" + filtreval + "</span>%] " +
                "[Bulunan: <span style='color:red;'>" + gosterilen + "</span>]"
            );
        } else {
            $('._rows').removeClass("hide");
            $('#filtreKelime').html("");
        }
    }

    $('#filterBInp').bind("keydown", function (event) {
        if (event.keyCode == 13) {
            Filtrele();
            event.preventDefault();
        }
    });
</script>