@using WebApp.Models
@using BiskaUtil
@model FrProgramEgitmen
@{
    Layout = "~/Views/Shared/_LayoutSelectPdfCss.cshtml"; 
}

<table style="width:100%;table-layout:fixed;margin-bottom:1px;font-size:15pt;" class="table">
    <tr class="success">
        <td style="text-align:center;font-weight:bold;">ÖĞRETİM ELEMANI DERS YÜKÜ BİLDİRİM FORMU</td>
    </tr>
</table>
<div class="panel" id="ebeyan_@Model.EOBirimDonemleriEgitmenID" style="margin: 0px; padding: 0px;">
    <div class="panel-body" style="margin: 0px; padding: 0px;">
        <div class="panel panel-info">
            <div class="panel-body" style="padding:5px;">
                <div class="panel panel-default" style="padding: 0px; margin: 0px;">

                    <table style="width:100%;table-layout:fixed;margin-bottom:1px;font-size:13pt;" class="table">
                        <tr>
                            <td>
                                <table style="width:100%;table-layout:fixed;">
                                    <tr>
                                        <th width="130">Dönem</th>
                                        <th width="5">:</th>
                                        <td>@Model.DonemAdi</td>
                                    </tr>
                                </table>
                            </td>
                            <td width="480px;">
                                <table>
                                    <tr>
                                        <th width="130">Hafta</th>
                                        <th width="5">:</th>
                                        <td>@Model.HaftaSelectedText</td>
                                    </tr>
                                </table>

                            </td>
                        </tr>
                        <tr>
                            <td>
                                <table style="width:100%;table-layout:fixed;">
                                    <tr>
                                        <th width="130">Ad Soyad / Sicil</th>
                                        <th width="5">:</th>
                                        <td>@Model.EgitmenGirisCikisBilgi.AdSoyad / @Model.EgitmenGirisCikisBilgi.SicilNo</td>
                                    </tr>
                                </table>
                            </td>
                            <td>
                                <table>
                                    <tr>
                                        <th width="130">Kadro Ünvanı</th>
                                        <th width="5">:</th>
                                        <td>@Model.EgitmenGirisCikisBilgi.KadroUnvanAdi</td>
                                    </tr>
                                </table>
                            </td>
                        </tr>
                        <tr>
                            <td>
                                <table style="width:100%;table-layout:fixed;">
                                    <tr>
                                        <th width="130">Ö.Elemanı Tipi</th>
                                        <th width="5">:</th>
                                        <td>@Model.EgitmenGirisCikisBilgi.EgitmenTipAdi</td>
                                    </tr>
                                </table>
                            </td>
                            <td>
                                <table>
                                    <tr>
                                        <th width="130">Ekders Ünvanı</th>
                                        <th width="5">:</th>
                                        <td>@Model.EgitmenGirisCikisBilgi.EkdersUnvanAdi</td>
                                    </tr>
                                </table>
                            </td>
                        </tr>
                        <tr>
                            <td>
                                <table style="width:100%;table-layout:fixed;">
                                    <tr>
                                        <th width="130">Kadro Birimi</th>
                                        <th width="5">:</th>
                                        <td>@Model.EgitmenGirisCikisBilgi.KadroBirimAdi</td>
                                    </tr>
                                </table>
                            </td>
                            <td>
                                <table>
                                    <tr>
                                        <th width="130">İdari Görev</th>
                                        <th width="5">:</th>
                                        <td>@Model.EgitmenGirisCikisBilgi.IdariUnvanAdi</td>
                                    </tr>
                                </table>

                            </td>
                        </tr>
                        <tr>
                            <td>
                                <table style="width:100%;table-layout:fixed;">
                                    <tr>
                                        <th width="130">Ekders Birimi</th>
                                        <th width="5">:</th>
                                        <td>@Model.EgitmenGirisCikisBilgi.EkdersBirimAdi</td>
                                    </tr>
                                </table>
                            </td>
                            <td>
                                <table>
                                    <tr>
                                        <th width="130">Ders Yükü</th>
                                        <th width="5">:</th>
                                        <td>@Model.EgitmenGirisCikisBilgi.DersYuku Saat</td>
                                    </tr>
                                </table>
                            </td>
                        </tr>
                    </table>

                </div>
            </div>
        </div>
        <div class="panel panel-info">
            <div class="panel-body" style="padding:5px;">
                <div class="panel panel-default" style="padding: 0px; margin: 0px;">
                    <table class="table" style="margin-bottom:0px;">
                        <thead>
                            <tr>
                                <th height="20" width="140"></th>
                                <th width="45" style="font-size:13pt;" title="Öğretim Tipi">Ö.T</th>
                                <th width="90" style="font-size:13pt;">Gün</th>
                                <th width="195" style="font-size:13pt;">Saat</th>
                                <th width="80" style="font-size:13pt;">Toplam</th>
                                <th style="font-size:13pt;">Ders</th>
                                <th width="45" style="font-size:13pt;">Kredi</th>
                                <th width="40" style="font-size:13pt;text-align:right;">Grp</th>
                                <th width="40" style="font-size:13pt;text-align:right;" title="Öğrenci Sayısı">Ö.S</th>
                                <th width="60" style="font-size:13pt;text-align:right;">Brm</th>
                                <th width="60" style="font-size:13pt;text-align:right;"></th>
                            </tr>
                        </thead>
                        <tbody>
                            <tr>
                                <td colspan="11" style="padding:0px;">
                                    <table class="table table-hover" style="width:100%;table-layout:fixed;margin-bottom:1px;" id="Filter_Table_Bp_@Model.EOBirimDonemleriEgitmenID">
                                        @{
                                            int RowIndex = 0;
                                            foreach (var item in Model.BeyanBilgisi.BeyanList)
                                            {
                                                RowIndex++; 
                                                <tr class="MainRow" style="@item.PuantajDurumu.Style">
                                                    <td class="" width="140">@item.PuantajDurumu.PuantajDurumAdi</td>
                                                    <td width="45" title="@item.OgretimTipAdi - @item.OgretimAdi">@item.OgretimTipKisaAdi</td>
                                                    <td width="90" class="Filter_Col_Bp_@Model.EOBirimDonemleriEgitmenID">
                                                        @item.GunAdi
                                                    </td>
                                                    <td width="195" class="Filter_Col_Bp_@Model.EOBirimDonemleriEgitmenID">
                                                        @string.Join(", ", item.Saatler)
                                                    </td>
                                                    <td width="80">
                                                        <i class="fa-lg"> @item.Saatler.Count</i> Saat
                                                    </td>
                                                    <td class="Filter_Col_Bp_@Model.EOBirimDonemleriEgitmenID">
                                                        @item.DersAdi
                                                    </td>
                                                    <td width="45" class="Filter_Col_Bp_@Model.EOBirimDonemleriEgitmenID" title="@item.DersTurAdi">
                                                        @item.DersTurKod @(item.PuantajDurumID != PuantajDurum.KurumDisi ? (item.DersTurKod == DersTuru.T ? "(" + item.TSaat + ")" : "(" + item.DSaat + ")") : "")
                                                    </td>
                                                    <td width="40" style="text-align:right;" class="Filter_Col_Bp_@Model.EOBirimDonemleriEgitmenID">
                                                        @item.GrupNo
                                                    </td>
                                                    <td width="40" style="text-align:right;" class="Filter_Col_Bp_@Model.EOBirimDonemleriEgitmenID">
                                                        @item.OgrenciSayisi
                                                    </td>
                                                    <td width="60" style="text-align:right;" title="@item.BirimAdi" class="Filter_Col_Bp_@Model.EOBirimDonemleriEgitmenID">
                                                        @item.BirimKisaAdi
                                                    </td>
                                                    <td width="60" style="text-align:right;">@item.OgretimKisaAdi</td>
                                                </tr>
                                                if (item.OgrencilerDctList.Count > 0)
                                                {
                                                    int inx2 = 0;
                                                    <tr class="MainRow2">
                                                        <td colspan="11" style="padding: 0px 0px 0px 35px;">
                                                            <div class="panel" style="padding-top:0px;margin-top:0px;">
                                                                @if (item.OgrencilerDctList.Count > 4)
                                                                {

                                                                    <div class="col-md-12" style="padding:0px;">
                                                                        <table class="table table-hover" style="width:100%;table-layout:fixed;margin:0px;font-size:10pt;">
                                                                            <thead>
                                                                                <tr class="">
                                                                                    <th width="25"></th>
                                                                                    <th>Öğrenci No - Ad Soyad</th>
                                                                                </tr>
                                                                            </thead>
                                                                            @foreach (var itemOdct in item.OgrencilerDctList)
                                                                            {
                                                                            <tr class="">
                                                                                <td>@itemOdct.Value.Count)</td>
                                                                                <td>@string.Join(", ", itemOdct.Value.Select(s => s.OgrenciNo + "-" + s.AdSoyad).ToList())</td>
                                                                            </tr>
                                                                            }
                                                                        </table>
                                                                    </div>
                                                                }
                                                                else
                                                                {
                                                                    foreach (var itemOdct in item.OgrencilerDctList)
                                                                    {
                                                                        <div class="col-md-@(12 / item.OgrencilerDctList.Count)" style="padding:0px;">
                                                                            <table class="table table-hover" style="width:100%;table-layout:fixed;margin:0px;font-size:10pt;">
                                                                                <thead>
                                                                                    <tr class="">
                                                                                        <th width="25"></th>
                                                                                        <th width="65">Ogrenci No</th>
                                                                                        <th>Ad Soyad</th>
                                                                                    </tr>
                                                                                </thead>
                                                                                @foreach (var itemO in itemOdct.Value)
                                                                                {
                                                                                    inx2++;
                                                                                    <tr class="">
                                                                                        <td>@inx2)</td>
                                                                                        <td>@itemO.OgrenciNo</td>
                                                                                        <td>@itemO.AdSoyad @(itemO.SeciliGundeAyrildi ? " (" + itemO.AyrilisTarihi.ToDateString() + ")" : "")</td>
                                                                                    </tr>
                                                                                }
                                                                            </table>
                                                                        </div>
                                                                    }
                                                                }
                                                            </div>
                                                        </td>
                                                    </tr>
                                                }
                                            }
                                            if (RowIndex == 0)
                                            {
                                                <tr>
                                                    <td colspan="11" style="color:maroon;font-size:16pt; text-align:center;height:250px;">@(Model.BeyanDurum.BeyanDurumID == BeyanDurum.ProgramOlusturulmadi ? "Beyan Oluşturulmadı." : "Seçilen hafta için listelenecek kayıt bulunamadı.")</td>
                                                </tr>
                                            }
                                        }
                                    </table>
                                </td>
                            </tr>

                        </tbody>

                    </table>
                </div>
            </div>
        </div>
        <div class="panel panel-info">
            <div class="panel-body" style="padding:5px;">
                <div class="panel panel-default" style="padding: 0px; margin: 0px;">
                    <table class="table" style="margin-bottom:0px;">
                        <thead>
                            <tr>
                                <th style="font-size:13pt;"> </th>
                                <th width="120" style="font-size:13pt;text-align:center;">
                                    1. Öğretim
                                    <table style="width:100%;table-layout:fixed;">
                                        <tr>
                                            <th style="font-size:13pt;text-align:center;">T</th>
                                            <th style="font-size:13pt;text-align:center;">D</th>
                                        </tr>
                                    </table>
                                </th>
                                <th width="120" style="font-size:13pt;text-align:center;">
                                    2. Öğretim
                                    <table style="width:100%;table-layout:fixed;">
                                        <tr>
                                            <th style="font-size:13pt;text-align:center;">T</th>
                                            <th style="font-size:13pt;text-align:center;">D</th>
                                        </tr>
                                    </table>
                                </th>
                                <th width="120" style="font-size:13pt;text-align:center;">
                                    Tezsiz YL
                                    <table style="width:100%;table-layout:fixed;">
                                        <tr>
                                            <th style="font-size:13pt;text-align:center;">T</th>
                                            <th style="font-size:13pt;text-align:center;">D</th>
                                        </tr>
                                    </table>
                                </th>
                                <th width="120" style="font-size:13pt;text-align:center;">
                                    Uzaktan E.
                                    <table style="width:100%;table-layout:fixed;">
                                        <tr>
                                            <th style="font-size:13pt;text-align:center;">T</th>
                                            <th style="font-size:13pt;text-align:center;">D</th>
                                        </tr>
                                    </table>
                                </th>
                                <th width="90" style="font-size:13pt;text-align:right;">Toplam</th>
                            </tr>
                        </thead>
                        <tbody>
                            <tr>
                                <td colspan="6" style="padding:0px;">
                                    <table class="table table-hover" style="width:100%;table-layout:fixed;margin-bottom:1px;">
                                        @{

                                            foreach (var item in Model.BeyanBilgisi.BeyanSayisalList)
                                            { 
                                                <tr class="">
                                                    <td style="font-size:13pt;@(item.Toplam > 0 ? "font-weight:bold;" : "")">@item.ToplamTipAdi</td>
                                                    <td width="60" style="text-align:center;font-size:13pt; @(item.Ogretim1T>0?"font-weight:bold;":"")">@item.Ogretim1T</td>
                                                    <td width="60" style="text-align:center;font-size:13pt; @(item.Ogretim1D>0?"font-weight:bold;":"")">@item.Ogretim1D</td>
                                                    <td width="60" style="text-align:center;font-size:13pt; @(item.Ogretim2T>0?"font-weight:bold;":"")">@item.Ogretim2T</td>
                                                    <td width="60" style="text-align:center;font-size:13pt; @(item.Ogretim2D>0?"font-weight:bold;":"")">@item.Ogretim2D</td>
                                                    <td width="60" style="text-align:center;font-size:13pt; @(item.TYLT>0?"font-weight:bold;":"")">@item.TYLT</td>
                                                    <td width="60" style="text-align:center;font-size:13pt; @(item.TYLD>0?"font-weight:bold;":"")">@item.TYLD</td>
                                                    <td width="60" style="text-align:center;font-size:13pt; @(item.UzaktanT>0?"font-weight:bold;":"")">@item.UzaktanT</td>
                                                    <td width="60" style="text-align:center;font-size:13pt; @(item.UzaktanD>0?"font-weight:bold;":"")">@item.UzaktanD</td>
                                                    <td width="90" style="text-align:right;font-size:13pt;@(item.Toplam>0?"font-weight:bold;":"")">@item.Toplam</td>
                                                </tr>

                                            }
                                        }
                                    </table>
                                </td>
                            </tr>

                        </tbody>

                    </table>
                </div>
            </div>
        </div>
        
    </div>
    <table style="width:100%;table-layout:fixed;">

        <tr>
            <td height="5"></td>
            <td height="5" width="400"></td>
        </tr>
        <tr>
            <td style="padding-left:150px;">
                <table>
                    <tr>
                        <th style="text-align:center;" height="10">Öğretim Elemanı</th>
                    </tr>
                    <tr>
                        <td height="10">@Model.EgitmenGirisCikisBilgi.EkdersUnvanAdi @Model.EgitmenGirisCikisBilgi.AdSoyad</td>
                    </tr>
                </table>
            </td>
            <td>
                <table>
                    <tr>
                        <th height="10" style="text-align:center;">Bölüm Başkanı</th>
                    </tr>
                    <tr>
                        <td height="10"></td>
                    </tr>
                </table>
            </td>
        </tr>
        <tr>
            <td height="20"></td>
            <td height="20"></td>
        </tr>
    </table>
</div>
