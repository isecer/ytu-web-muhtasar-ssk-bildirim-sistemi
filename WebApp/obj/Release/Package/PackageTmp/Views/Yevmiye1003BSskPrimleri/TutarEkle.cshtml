@using Database
@using WebApp.Models
@model Yevmiyeler1003BSskPrimBoclari
@{
    Layout = null;
}
@using (Ajax.BeginForm("TutarEkle", "Yevmiye1003BSskPrimleri", null, new AjaxOptions() { HttpMethod = "POST" }, new { enctype = "multipart/form-data", id = "frmTutarKayit", @class = "form-horizontal" }))
{
    @Html.Hidden("Yil", Model.Yil)
    @Html.Hidden("AyID", Model.AyID)
    @Html.Hidden("YevmiyeHarcamaBirimID", Model.YevmiyeHarcamaBirimID)
    @Html.Hidden("YevmiyeBelgeKodID", Model.YevmiyeBelgeKodID)
    <div class="col-md-12" style="overflow-x:auto; max-height:600px;">
        <div class="widget widget-default" style="border-top:1px solid;border-top-color:lightgray; margin-bottom:8px;padding:6px 10px;min-height:20px;">
            <table style="width:100%;">
                <tbody>
                    <tr>
                        <td style="padding-left:10px;text-align:left;">
                            <table style="width:100%;">
                                <tbody>
                                    <tr>
                                        <td width="140">Yıl</td>
                                        <td width="10">:</td>
                                        <td>@Model.Yil</td>
                                    </tr>
                                    <tr>
                                        <td>Ay</td>
                                        <td>:</td>
                                        <td>@Model.Aylar.AyAdi</td>
                                    </tr>
                                    <tr>
                                        <td>Harcama Birimi</td>
                                        <td>:</td>
                                        <td>@Model.YevmiyelerHarcamaBirimleri.VergiKimlikNo - @Model.YevmiyelerHarcamaBirimleri.BirimAdi</td>
                                    </tr>
                                    <tr>
                                        <td>Belge Kodu</td>
                                        <td>:</td>
                                        <td>@Model.YevmiyelerBelgeKodlari.BelgeKodu - @Model.YevmiyelerBelgeKodlari.BelgeAdi</td>
                                    </tr>
                                    <tr>
                                        <td>Borç Tutarı</td>
                                        <td>:</td>
                                        <td class="form-group">
                                            @Html.TextBox("Tutar", Model.Tutar.ToEmptyStringZero(), new { @class = "form-control", autocomplete = "off" })
                                        </td>
                                    </tr>
                                </tbody>
                            </table>
                        </td>
                    </tr>
                </tbody>
            </table>
        </div>
    </div>
}

