@using WebApp.Models
@using BiskaUtil
@using Database
@model IEnumerable<CheckObject<Maddeler>>
@{
    Layout = null;
}
<div class="panel panel-info">
    <div class="panel-heading padding-0">
        <h3 class="panel-title">Birime Ait Maddeleri Seçiniz</h3>
        <span id="FilterInfo_Mdl" style="float:left;">
        </span>
        <ul class="panel-controls">
            <li>
                <table>
                    <tr>
                        <td width="20"><input type="checkbox" style="width:18px;height:18px;margin-top:4px;" value="true" onchange="setTumu(this,'Filter_Table_Mdl','MaddeID')"></td>
                        <td style="cursor:pointer;font-size:10pt;" onclick="$(this).parents('tr').first().find('input').click();">Tümünü Seç</td>
                    </tr>
                </table>
            </li>
            <li>
                <span class="label label-primary label-form" style="padding:1px;padding-left:3px;padding-right:3px;">
                    <input style="color:maroon;width:250px;" type="text" autocomplete="off" name="search" onkeypress="return FilterInputKeyPress(this, event,'Mdl');" placeholder="ara...">
                </span>
            </li>
        </ul>
    </div>
    <div class="panel-body padding-0">
        <table class="table" style="width:100%;table-layout:fixed;margin-bottom:0px;">
            <tr>
                <td colspan="3">
                    <div style="max-height: 230px; overflow: auto;">
                        <table class="table chks" style="width:100%;table-layout:fixed;margin-bottom:0px;" id="Filter_Table_Mdl">
                            @foreach (var item in Model)
                            {
                                <tr class="tr_@item.Value.MaddeID MainRow @(item.Checked.Value?"success":"")">
                                    <td class="Filter_Col_Mdl">
                                        <table style="width:100%;">
                                            <tr>
                                                <td width="25"><input type="checkbox" class="chk_" onclick="RwClick(@item.Value.MaddeID);checkedInfo('#Filter_Table_Mdl');" style="width:18px;height:18px;" name="MaddeID" id="chk_@item.Value.MaddeID" value="@item.Value.MaddeID" @item.Checked.ToChecked()></td>
                                                <td width="40" style="cursor:pointer;" onclick="$('#chk_@item.Value.MaddeID').click();"><b>@item.Value.MaddeKod</b></td>
                                                <td style="cursor:pointer;" onclick="$('#chk_@item.Value.MaddeID').click();">@item.Value.MaddeAdi</td>
                                            </tr>
                                        </table>
                                    </td>
                                </tr>
                            }
                        </table>
                    </div>
                </td>
            </tr>
        </table>
    </div>
    <div class="panel-footer padding-0">
        <table>
            <tr>
                <td id="footerInfo">
                    Toplam: @Model.Count(), Seçilen: @Model.Where(p => p.Checked.Value).Count()
                </td>
            </tr>
        </table>

    </div>
</div>



