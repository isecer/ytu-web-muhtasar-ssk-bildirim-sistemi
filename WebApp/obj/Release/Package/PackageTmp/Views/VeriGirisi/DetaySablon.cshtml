@using WebApp.Models
@using BiskaUtil
@model VeriGirisModel
@{
    Layout = null;
    var KayitYetki = Model.SurecBilgi.IsAktif && RoleNames.VeriGirisiKayitYetkisi.InRole();
    var OnayYetki = Model.SurecBilgi.IsAktif && RoleNames.VeriGirisiOnayYetkisi.InRole();
    //var qHeight = Model.FaaliyetData.Count * 96;
    //var pHeight = 33;
    //if (Model.VeriGirisi.IsPlanlananDegerOlacak) { pHeight += 33; }
    //if (Model.VeriGirisi.IsCokluVeriGirisi) { pHeight += Model.VeriGirisi.VASurecleriMaddeAys.Count * 33; }
    //else { pHeight += 33; }

    //if (qHeight > pHeight)
    //{
    //    qHeight = pHeight;
    //}
    //if (qHeight < 295) { qHeight = 295; }
    var RwID = Model.VASurecID + "_" + Model.BirimID + "_" + @Model.MaddeID;

    var PlBgColor = Model.VeriGirisi.BirimMadde != null ? (Model.VeriGirisi.BirimMadde.PlanlananDeger.HasValue ? "#95b75d" : "#3fbae4") : "";
    var PlBgColor2 = Model.VeriGirisi.BirimMadde != null ? (Model.VeriGirisi.BirimMadde.PlanlananDegerGelecekYil.HasValue ? "#95b75d" : "#3fbae4") : "";


}

<table class="table table-bordered" style="margin:0px;">
    <tr>
        <td width="350" style="vertical-align:central;">
            <div class="panel" style="margin:0px;">
                <div class="panel-heading padding-0" style="padding:0px;margin:0px;">
                    <h3 class="panel-title">
                        <i class="fa fa-file-text-o fa-lg"></i>Maddeye Ait Birim Verileri
                    </h3>
                </div>
                <div class="panel-body" style="margin: 0px; padding: 0px;">
                    <table class="table table-hover table-bordered tblVeriGiris" style="margin:0px auto;">

                        @if (Model.VeriGirisi.IsPlanlananDegerOlacak)
                        {
                            <tr>
                                <td width="150" style="background-color:@PlBgColor;font-size:11pt;color:white;">@Model.SurecBilgi.Yil Yılı Planlanan Hedef</td>
                                <td width="10" style="color:@PlBgColor;font-size:14pt;">:</td>
                                <td width="120">
                                    <input type="text" class="form-control VeriGiris_@RwID" PlDgrBuYilOrGelecekYil="true" AyID="" style="font-size:12pt;font-weight:bold;color:@PlBgColor;text-align:right;" name="GirilenDeger" value="@(Model.VeriGirisi.BirimMadde != null ? String.Format("{0:0.###}", Model.VeriGirisi.BirimMadde.PlanlananDeger) : "")" />
                                </td>
                            </tr>


                        }
                        @if (Model.VeriGirisi.IsCokluVeriGirisi)
                        {
                            foreach (var item in Model.VeriGirisi.VASurecleriMaddeAys)
                            {
                                var Kayit = Model.VeriGirisi.VASurecleriMaddeGirilenDegers.Where(p => p.VASurecleriBirim.BirimID == Model.BirimID && p.VASurecleriMadde.MaddeID == Model.MaddeID && p.AyID == item.AyID).FirstOrDefault();
                                var _color = Kayit != null ? "#95b75d" : "#3fbae4";
                                <tr>
                                    <td width="150" style="background:@_color;font-size:11pt;color:white;">@item.Aylar.AyAdi Ayı Verisi</td>
                                    <td width="10" style="color:@_color;font-size:14pt;">:</td>
                                    <td width="120"><input type="text" class="form-control VeriGiris_@RwID" PlDgrBuYilOrGelecekYil="" AyID="@item.AyID" style="font-size:12pt;color:@_color; font-weight:bold;text-align:right;" name="GirilenDeger" value="@(Kayit != null ? String.Format("{0:0.###}", Kayit.GirilenDeger) : "")" /></td>
                                </tr>
                            }
                        }
                        else
                        {
                            var Kayit = Model.VeriGirisi.VASurecleriMaddeGirilenDegers.Where(p => p.VASurecleriBirim.BirimID == Model.BirimID && !p.AyID.HasValue && p.VASurecleriMadde.MaddeID == Model.MaddeID).FirstOrDefault();
                            var _color = Kayit != null ? "#95b75d" : "#3fbae4";

                            <tr>
                                <td width="150" style="background:@_color;font-size:11pt;color:white;">@Model.SurecBilgi.Yil Yılı Verisi</td>
                                <td width="10" style="color:@_color;font-size:14pt;">:</td>
                                <td width="120"><input type="text" class="form-control VeriGiris_@RwID" PlDgrBuYilOrGelecekYil="" AyID="" style="font-size:12pt;font-weight:bold;color:@_color;text-align:right;" name="GirilenDeger" value="@(Kayit != null ? String.Format("{0:0.###}", Kayit.GirilenDeger) : "")" /></td>
                            </tr>
                        }
                        @if (Model.VeriGirisi.IsPlanlananDegerOlacak)
                        {
                            <tr>
                                <td width="150" style="background-color:@PlBgColor2;font-size:11pt;color:white;">@(Model.SurecBilgi.Yil + 1) Yılı Planlanan Hedef</td>
                                <td width="10" style="color:@PlBgColor2;font-size:14pt;">:</td>
                                <td width="120">
                                    <input type="text" class="form-control VeriGiris_@RwID" PlDgrBuYilOrGelecekYil="false" AyID="" style="font-size:12pt;font-weight:bold;color:@PlBgColor2;text-align:right;" name="GirilenDeger" value="@(Model.VeriGirisi.BirimMadde != null ? String.Format("{0:0.###}", Model.VeriGirisi.BirimMadde.PlanlananDegerGelecekYil) : "")" />
                                </td>
                            </tr>
                        }
                        @{
                            var _colorF = Model.VeriGirisi.DosyaCount > 0 ? "#95b75d" : "#3fbae4";

                            <tr>
                                <td width="150" style="background:@_colorF;font-size:11pt;color:white;">
                                    Veri Kanıt Dosyası

                                    <a class="fa fa-folder-o fa-lg" href="javascript:void(0);" style="float:right;font-size:21pt;" onclick="fDialogVKD(@Model.VASurecID,@Model.BirimID,@Model.MaddeID)"></a>

                                </td>
                                <td width="10" style="color:@_colorF;font-size:14pt;">:</td>
                                <td width="120" style="color:@_colorF;font-size:12pt;text-align:right;font-weight:bold;">


                                    <span style="cursor:pointer;color:@_colorF;" onclick="fDialogVKD(@Model.VASurecID,@Model.BirimID,@Model.MaddeID)">Eklenen: <b>@Model.VeriGirisi.DosyaCount</b> </span>

                                </td>
                            </tr>

                            var _color2 = Model.VeriGirisi.VeriGirisiOnaylandi ? "#95b75d" : "#3fbae4";

                            <tr>
                                <td width="150" style="background:@_color2;font-size:11pt;color:white;">Veri Giriş Onay Durumu</td>
                                <td width="10" style="color:@_color2;font-size:14pt;">:</td>
                                <td width="120">
                                    @if (OnayYetki)
                                    {
                                        @Html.DropDownList("VeriGirisiOnaylandi", Model.SListVeriGirisOnayDurum, new { dir = "rtl", style = ("font-size:12pt;font-weight:bold;color:" + _color2), @class = ("form-control VeriGirisOnay_" + RwID), onchange = "VeriGirisOnay(this," + Model.VASurecID + "," + Model.BirimID + "," + Model.MaddeID + ",'" + RwID + "')" })
                                    }
                                    else
                                    {
                                        @Html.DropDownList("VeriGirisiOnaylandi", Model.SListVeriGirisOnayDurum, new { disabled = "disabled", dir = "rtl", style = ("font-size:12pt;font-weight:bold;color:" + _color2), @class = ("form-control VeriGirisOnay_" + RwID), onchange = "VeriGirisOnay(this," + Model.VASurecID + "," + Model.BirimID + "," + Model.MaddeID + ",'" + RwID + "')" })

                                    }
                                </td>
                            </tr>

                        }
                        @if (!Model.VeriGirisi.VeriGirisiOnaylandi && KayitYetki)
                        {
                            <tr>
                                <td colspan="3"><button type="button" style="width:100%;" class="btn btn-primary btn-condensed" onclick="VeriKayit(@Model.VASurecID,@Model.BirimID,@Model.MaddeID)"><i class="fa fa-save"></i> Kaydet</button></td>
                            </tr>
                        }

                    </table>
                </div>
            </div>
        </td>
        <td style="vertical-align:top;">

            <div class="panel" style="margin:0px;margin-top:4px;">
                <div class="panel-heading padding-0" style="padding:0px;margin:0px;">
                    <h3 class="panel-title">
                        <i class="fa fa-comments-o fa-lg"></i>Madde İle İlgili Girilen Veri Açıklamaları (@Model.AciklamaData.Count)
                    </h3>
                    <ul class="panel-controls">
                        <li><span class="label label-primary" style="cursor:pointer;" onclick="aDialogVG(@Model.VASurecID,@Model.BirimID,@Model.MaddeID,'')"><i class="fa fa-plus"></i> Açıklama Ekle</span></li>
                    </ul>
                </div>
                <div class="panel-body" style="margin: 0px; padding: 0px;">
                    <div class="" style="overflow:auto;height:140px;">
                        <table class="table table-hover">
                            <thead>
                                <tr>
                                    <th width="50">Ay</th>
                                    <th>Açıklama</th>
                                    <th width="110">Eklenme Tarihi</th>
                                    <th width="50" style="text-align:center;"></th>

                                </tr>
                            </thead>
                            <tbody>
                                @foreach (var item in Model.AciklamaData)
                                {
                                    <tr>

                                        <td id="tdAAyAdi_@item.VASurecleriMaddeEklenenAciklamaID">@(item.AyID.HasValue ? item.Aylar.AyAdi : "Genel")</td>
                                        <td id="tdAAciklama_@item.VASurecleriMaddeEklenenAciklamaID">
                                            @item.Aciklama
                                        </td>
                                        <td>@item.IslemTarihi.ToFormatDateAndTime()</td>
                                        <td>
                                            <a href="javascript:void(0)" onclick="aDialogVG(@Model.VASurecID,@Model.BirimID,@Model.MaddeID,@item.VASurecleriMaddeEklenenAciklamaID)"><i class="fa fa-edit fa-lg"></i></a>
                                            @if (!Model.VeriGirisi.VeriGirisiOnaylandi && KayitYetki)
                                            {
                                                <a href="javascript:void(0)" onclick="AciklamaSilmeOnay(this,@item.VASurecleriMaddeEklenenAciklamaID,@Model.MaddeID)"><i class="fa fa-trash-o fa-lg tooltips" data-style="blue" data-original-title="Sil"></i></a>
                                            }
                                        </td>
                                    </tr>

                                }
                            </tbody>
                        </table>
                    </div>
                </div>
            </div>
            <div class="panel" style="margin:0px; margin-top:4px;">
                <div class="panel-heading padding-0" style="padding:0px;margin:0px;">
                    <h3 class="panel-title">
                        <i class="fa fa-list fa-lg"></i>Madde İle İlgili Faaliyetler (@Model.FaaliyetData.Count)
                    </h3>

                </div>
                <div class="panel-body" style="margin: 0px; padding: 0px;">
                    <div class="" style="overflow:auto;max-height:250px;">
                        <div class="tasks">
                            @foreach (var item in Model.FaaliyetData)
                            {
                                <div class="task-item task-info" style="padding:3px;">
                                    <table class="" style="margin:0px;">

                                        <tr>
                                            <td width="120" style="font-weight:bold;color:cadetblue;background:#f1f5f9;">Faaliyet Adı</td>
                                            <td width="10" style="font-weight:bold;color:cadetblue;background:#f1f5f9;">:</td>
                                            <td class="Filter_Col_B_@Model.MaddeID" style="font-size:11pt;padding-bottom:3px;color:cadetblue;">
                                                [@item.FaaliyetKod] - @item.FaaliyetAdi
                                            </td>
                                        </tr>
                                        @if (item.TakipGostergesi != null)
                                        {
                                            <tr>
                                                <td style="font-weight:bold;color:chocolate;background:#f1f5f9;">Takip Göstergesi</td>
                                                <td style="font-weight:bold;color:chocolate;background:#f1f5f9;">:</td>
                                                <td style="color:chocolate;font-size:11pt;">
                                                    @item.TakipGostergesi
                                                </td>
                                            </tr>
                                        }
                                        <tr>
                                            <td style="font-weight:bold;color:chocolate;background:#f1f5f9;">Planlanan Zaman</td>
                                            <td style="font-weight:bold;color:chocolate;background:#f1f5f9;">:</td>
                                            <td>

                                                <ul class="list-tags">
                                                    @foreach (var itemFa in item.FaaliyetAylari.OrderBy(o => o.AyID))
                                                    {
                                                        <li><a href="javascript:void(0);" style="color:chocolate;"><span class="fa fa-tag"></span> @itemFa.AyAdi</a></li>
                                                    }
                                                </ul>
                                            </td>
                                        </tr>
                                        <tr>
                                            <td style="font-weight:bold;color:chocolate;background:#f1f5f9;">İlgili Kaynaklar</td>
                                            <td style="font-weight:bold;color:chocolate;background:#f1f5f9;">:</td>
                                            <td>
                                                <ul class="list-tags">
                                                    @foreach (var itemKa in item.FaaliyetKaynaklari.OrderBy(o => o.KaynakAdi))
                                                    {
                                                        <li><a href="javascript:void(0);" style="color:chocolate;"><span class="fa fa-tag"></span> @itemKa.KaynakAdi</a></li>
                                                    }
                                                </ul>
                                            </td>
                                        </tr>
                                    </table>

                                </div>
                            }



                        </div>

                    </div>
                </div>
            </div>

        </td>
    </tr>
</table>



