@using WebApp.Models
@using BiskaUtil
@model FrSurecIslemleri
@{
    Layout = null;
}

<div class="panel" id="PnlBirim_@Model.VASurecID" style="margin:0px;">
    <div class="panel-heading padding-0" style="padding:0px;margin:0px;">
        <h3 class="panel-title">
            <i class="fa fa-home"></i>Birimler
        </h3>
        <ul class="panel-controls">

            <li id="FilterInfo_B_@Model.VASurecID">
            </li>
            <li>
                <span class="label label-primary label-form" style="padding:1px;padding-left:3px;padding-right:3px;">
                    <input style="color:maroon;" type="text" autocomplete="off" name="search" onkeypress="return FilterInputKeyPress(this, event,'B_@Model.VASurecID');" placeholder="ara...">
                </span>

            </li>
            <li>
                <span class="label label-primary" style="padding:1px;padding-left:3px;padding-right:3px;">
                    Seçilen Ay:
                    @Html.DropDownList("SelectListAy", Model.SListAy, new { style = "color:black;", onchange = "setselectedAyID($(this).val()," + Model.VASurecID + "); SubData(" + Model.VASurecID + ");" })
                </span>
            </li>
            <li>
                <span class="label label-primary" style="padding:1px;padding-left:3px;padding-right:3px;">
                    Veri Giriş Durumu:
                    @Html.DropDownList("SelectListBirimDurum", Model.SListBirimDurum, new { style = "color:black;", onchange = "setselectedBirimDurumID($(this).val()," + Model.VASurecID + "); SubData(" + Model.VASurecID + ");" })
                </span>
            </li>
        </ul>
    </div>
    <div class="panel" style="margin: 0px; padding: 0px;">
        <div class="panel-body" style="margin: 0px; padding: 0px;">
            <div class="col-md-12" style="height:410px;">
                <table class="table" style="margin-bottom:0px;">
                    <thead>
                        <tr>
                            <th height="40" width="75"></th>
                            <th style="font-size:10pt;">Birim Adı</th>
                            <th style="font-size:10pt;" width="220">Veri Giriş Tipi</th>
                            <th style="font-size:10pt;text-align:center;" width="180">Veri Giriş Durumu</th>
                        </tr>
                    </thead>
                    <tbody>
                        <tr>
                            <td colspan="6" style="padding:0px;">
                                <div class="scrolkikko" style="max-height:365px;overflow:auto;">
                                    <table class="table table-hover" style="width:100%;table-layout:fixed;" id="Filter_Table_B_@Model.VASurecID">
                                        @{
                                            int RowIndex = 0;
                                            foreach (var item in Model.BirimData)
                                            {
                                                RowIndex++;
                                                var rowGD = "B-" + Model.VASurecID + "-" + item.BirimID;

                                                <tr class="MainRow">
                                                    <td width="75">
                                                        <table>
                                                            <tr>
                                                                <td style="width:30px;">@RowIndex</td>
                                                                @*<td>
                                                                        <ul class="panel-controls">
                                                                            <li id="iShow_@rowGD" onclick="ShowDetail2(@Model.VASurecID,@item.BirimID,'@rowGD',false)">
                                                                                <a href="javascript:void(0)"><span class="fa fa-angle-up"></span> </a>
                                                                            </li>
                                                                        </ul>
                                                                    </td>*@
                                                            </tr>
                                                        </table>
                                                    </td>
                                                    <td class="Filter_Col_B_@Model.VASurecID">
                                                        @item.BirimAdi
                                                    </td>
                                                    <td width="220" style="color:black;font-weight:bold;">@item.VeriGirisTipAdi</td>
                                                    <td width="180" style="text-align:center;color:@(item.VeriGirisVar?"#95b75d":"Maroon");font-weight:bold;">@(item.VeriGirisVar ? "Veri Girişi Var" : "Veri Girişi Yok")</td>
                                                </tr>

                                            }
                                        }
                                    </table>
                                </div>
                            </td>
                        </tr>
                    </tbody>
                </table>
            </div>
        </div>
    </div>
</div>
<script>

        //$(function () {
        //    $('.scrolkikko').slimScroll({
        //        color: 'red',
        //        height: '565px'
        //    });
        //})
</script>