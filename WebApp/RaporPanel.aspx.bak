<%@ Page Language="C#" AutoEventWireup="true" CodeBehind="RaporPanel.aspx.cs" Inherits="WebApp.RaporPanel" %>

<%@ Register Assembly="DevExpress.XtraReports.v17.1.Web, Version=17.1.3.0, Culture=neutral, PublicKeyToken=b88d1754d700e49a" Namespace="DevExpress.XtraReports.Web" TagPrefix="dx" %>


<!DOCTYPE html>

<html xmlns="http://www.w3.org/1999/xhtml">
<head runat="server">
    <title></title>
</head>
<body>
    <form id="form1" runat="server" style="padding: 0px;">
        <dx:ASPxDocumentViewer ID="dcmntViewer" runat="server" EnableTheming="True" Theme="Aqua" ToolbarMode="Ribbon"></dx:ASPxDocumentViewer>
    </form>

</body>
</html>

<script src="Scripts/jquery-1.11.3.min.js"></script>
<script>
    $(function () {
        var autoWidth = '<%=ViewState["autoWidth"]%>';  
        if (autoWidth != "True") setWidth();
        setTimeout(function () {
            $('#form1').prev().remove()
        }, 600)
      
    }); 
    function setWidth() {
        setTimeout(function () {
            $('#dcmntViewer_Splitter_Viewer_Div').css('width', '800px');
            $('#dcmntViewer_Splitter_Viewer_ContentFrame').css('width', '790px');
            $("#dcmntViewer_Splitter_Viewer_ContentFrame").contents().find('#report_div').css('width', '770px');
            $("#dcmntViewer_Splitter_Viewer_ContentFrame").contents().find('#report_div').find('table').first().css('width', '750px');
            setWidth();   
        }, 600)
    }
</script>
