    [Vw_BirimlerTree].[EskiUniteKodu] AS [EskiUniteKodu], 
    [Vw_BirimlerTree].[IsyeriSiraNumarasi] AS [IsyeriSiraNumarasi], 
    [Vw_BirimlerTree].[IlKodu] AS [IlKodu], 
