    <EntitySet Name="KullanicilarLog" EntityType="Self.KullanicilarLog" store:Type="Tables" store:Schema="dbo">
      <DefiningQuery>SELECT 
    [KullanicilarLog].[KullaniciID] AS [KullaniciID], 
    [KullanicilarLog].[YetkiGrupID] AS [YetkiGrupID], 
    [KullanicilarLog].[IsAkademikOrIdari] AS [IsAkademikOrIdari], 
    [KullanicilarLog].[AlternatifKadroTipID] AS [AlternatifKadroTipID], 
    [KullanicilarLog].[EgitmenTipID] AS [EgitmenTipID], 
    [KullanicilarLog].[Ad] AS [Ad], 
    [KullanicilarLog].[Soyad] AS [Soyad], 
    [KullanicilarLog].[TcKimlikNo] AS [TcKimlikNo], 
    [KullanicilarLog].[SicilNo] AS [SicilNo], 
    [KullanicilarLog].[KadroBirimID] AS [KadroBirimID], 
    [KullanicilarLog].[EkdersBirimID] AS [EkdersBirimID], 
    [KullanicilarLog].[KadroUnvanID] AS [KadroUnvanID], 
    [KullanicilarLog].[EkdersUnvanID] AS [EkdersUnvanID], 
    [KullanicilarLog].[IdariUnvanID] AS [IdariUnvanID], 
    [KullanicilarLog].[DersYuku] AS [DersYuku], 
    [KullanicilarLog].[BaslangicTarihi] AS [BaslangicTarihi], 
    [KullanicilarLog].[BitisTarihi] AS [BitisTarihi], 
    [KullanicilarLog].[CepTel] AS [CepTel], 
    [KullanicilarLog].[EMail] AS [EMail], 
    [KullanicilarLog].[ResimAdi] AS [ResimAdi], 
    [KullanicilarLog].[KullaniciAdi] AS [KullaniciAdi], 
    [KullanicilarLog].[Sifre] AS [Sifre], 
    [KullanicilarLog].[SifresiniDegistirsin] AS [SifresiniDegistirsin], 
    [KullanicilarLog].[IsActiveDirectoryUser] AS [IsActiveDirectoryUser], 
    [KullanicilarLog].[IsAdmin] AS [IsAdmin], 
    [KullanicilarLog].[Aciklama] AS [Aciklama], 
    [KullanicilarLog].[ParolaSifirlamaKodu] AS [ParolaSifirlamaKodu], 
    [KullanicilarLog].[ParolaSifirlamGecerlilikTarihi] AS [ParolaSifirlamGecerlilikTarihi], 
    [KullanicilarLog].[FixedHeader] AS [FixedHeader], 
    [KullanicilarLog].[FixedSidebar] AS [FixedSidebar], 
    [KullanicilarLog].[ScrollSidebar] AS [ScrollSidebar], 
    [KullanicilarLog].[RightSidebar] AS [RightSidebar], 
    [KullanicilarLog].[CustomNavigation] AS [CustomNavigation], 
    [KullanicilarLog].[ToggledNavigation] AS [ToggledNavigation], 
    [KullanicilarLog].[BoxedOrFullWidth] AS [BoxedOrFullWidth], 
    [KullanicilarLog].[ThemeName] AS [ThemeName], 
    [KullanicilarLog].[BackgroundImage] AS [BackgroundImage], 
    [KullanicilarLog].[IsAktif] AS [IsAktif], 
    [KullanicilarLog].[OlusturmaTarihi] AS [OlusturmaTarihi], 
    [KullanicilarLog].[LastLogonDate] AS [LastLogonDate], 
    [KullanicilarLog].[LastLogonIP] AS [LastLogonIP], 
    [KullanicilarLog].[IslemYapanID] AS [IslemYapanID], 
    [KullanicilarLog].[IslemTarihi] AS [IslemTarihi], 
    [KullanicilarLog].[IslemYapanIP] AS [IslemYapanIP]
    FROM [dbo].[KullanicilarLog] AS [KullanicilarLog]</DefiningQuery>
    </EntitySet>
