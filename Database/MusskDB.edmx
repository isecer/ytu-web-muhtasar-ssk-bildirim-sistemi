    [KullanicilarLog].[CustomNavigation] AS [CustomNavigation], 
    [KullanicilarLog].[ToggledNavigation] AS [ToggledNavigation], 
    [KullanicilarLog].[BoxedOrFullWidth] AS [BoxedOrFullWidth], 
    [KullanicilarLog].[ThemeName] AS [ThemeName], 
    [KullanicilarLog].[BackgroundImage] AS [BackgroundImage], 
    [KullanicilarLog].[IsAktif] AS [IsAktif], 
    [KullanicilarLog].[OlusturmaTarihi] AS [OlusturmaTarihi], 
    [KullanicilarLog].[LastLogonDate] AS [LastLogonDate], 
    [KullanicilarLog].[LastLogonIP] AS [LastLogonIP], 
    [KullanicilarLog].[IslemYapanID] AS [IslemYapanID], 
    [KullanicilarLog].[IslemTarihi] AS [IslemTarihi], 
    [KullanicilarLog].[IslemYapanIP] AS [IslemYapanIP]
